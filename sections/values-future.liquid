{% comment %}
  Values + Future Section
  - "Our Values" heading with 4 icon cards in a row
  - "Our Future" full-width image banner with overlay text
  - All configurable via customizer
  Add to: sections/values-future.liquid
{% endcomment %}

<section id="vf-{{ section.id }}">

  <!-- Our Values -->
  <div class="vf-values">
    {% if section.settings.values_heading != blank %}
      <h2 class="vf-values__title">{{ section.settings.values_heading }}</h2>
    {% endif %}

    <div class="vf-values__grid">
      {% for block in section.blocks %}
        {% if block.type == 'value_card' %}
          <div class="vf-card" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <div class="vf-card__icon">
                {{ block.settings.icon | image_url: width: 80 | image_tag: alt: block.settings.title, loading: 'lazy' }}
              </div>
            {% endif %}
            {% if block.settings.title != blank %}
              <h3 class="vf-card__title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.description != blank %}
              <p class="vf-card__desc">{{ block.settings.description }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <!-- Our Future -->
  {% if section.settings.future_heading != blank or section.settings.future_body != blank %}
    <div class="vf-future">
      {% if section.settings.future_image != blank %}
        {{ section.settings.future_image | image_url: width: 1920 | image_tag: class: 'vf-future__bg', alt: section.settings.future_heading, loading: 'lazy' }}
      {% endif %}
      <div class="vf-future__overlay"></div>
      <div class="vf-future__content">
        {% if section.settings.future_heading != blank %}
          <h2 class="vf-future__title">{{ section.settings.future_heading }}</h2>
        {% endif %}
        {% if section.settings.future_body != blank %}
          <p class="vf-future__body">{{ section.settings.future_body }}</p>
        {% endif %}
      </div>
    </div>
  {% endif %}

</section>

<style>
  #vf-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
  }

  /* ── Our Values ── */
  #vf-{{ section.id }} .vf-values {
    max-width: 1100px;
    margin: 0 auto;
    padding: 60px 20px;
    text-align: center;
  }

  #vf-{{ section.id }} .vf-values__title {
    font-size: 36px;
    font-weight: 700;
    font-style: italic;
    color: {{ section.settings.values_heading_color }};
    margin: 0 0 36px;
  }

  #vf-{{ section.id }} .vf-values__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  #vf-{{ section.id }} .vf-card {
    background: {{ section.settings.card_bg_color }};
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: 12px;
    padding: 32px 20px;
    text-align: center;
  }

  #vf-{{ section.id }} .vf-card__icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #vf-{{ section.id }} .vf-card__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  #vf-{{ section.id }} .vf-card__title {
    font-size: 18px;
    font-weight: 700;
    color: {{ section.settings.card_title_color }};
    margin: 0 0 12px;
  }

  #vf-{{ section.id }} .vf-card__desc {
    font-size: 14px;
    line-height: 1.6;
    color: {{ section.settings.card_text_color }};
    margin: 0;
  }

  /* ── Our Future ── */
  #vf-{{ section.id }} .vf-future {
    position: relative;
    width: 100%;
    min-height: 360px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  #vf-{{ section.id }} .vf-future__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #vf-{{ section.id }} .vf-future__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ section.settings.future_overlay_color }};
    opacity: {{ section.settings.future_overlay_opacity | divided_by: 100.0 }};
  }

  #vf-{{ section.id }} .vf-future__content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    text-align: center;
    padding: 60px 20px;
  }

  #vf-{{ section.id }} .vf-future__title {
    font-size: 36px;
    font-weight: 700;
    font-style: italic;
    color: {{ section.settings.future_text_color }};
    margin: 0 0 20px;
  }

  #vf-{{ section.id }} .vf-future__body {
    font-size: 15px;
    line-height: 1.7;
    color: {{ section.settings.future_text_color }};
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    #vf-{{ section.id }} .vf-values__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 550px) {
    #vf-{{ section.id }} .vf-values__grid {
      grid-template-columns: 1fr;
      max-width: 340px;
      margin: 0 auto;
    }

    #vf-{{ section.id }} .vf-values__title {
      font-size: 28px;
    }

    #vf-{{ section.id }} .vf-future {
      min-height: 280px;
    }

    #vf-{{ section.id }} .vf-future__title {
      font-size: 28px;
    }

    #vf-{{ section.id }} .vf-future__body {
      font-size: 14px;
    }
  }
</style>

{% schema %}
{
  "name": "Values + Future",
  "tag": "section",
  "class": "values-future-section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f5f0eb"
    },
    {
      "type": "header",
      "content": "Our Values"
    },
    {
      "type": "text",
      "id": "values_heading",
      "label": "Values Heading",
      "default": "Our Values"
    },
    {
      "type": "color",
      "id": "values_heading_color",
      "label": "Heading Color",
      "default": "#101a32"
    },
    {
      "type": "header",
      "content": "Card Styling"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border",
      "default": "#e8e0d8"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card Title Color",
      "default": "#101a32"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card Text Color",
      "default": "#555555"
    },
    {
      "type": "header",
      "content": "Our Future Banner"
    },
    {
      "type": "text",
      "id": "future_heading",
      "label": "Future Heading",
      "default": "Our Future"
    },
    {
      "type": "textarea",
      "id": "future_body",
      "label": "Future Body Text",
      "default": "We look forward to continuing our journey of innovation, developing more advanced and intuitive solutions for laundry care."
    },
    {
      "type": "image_picker",
      "id": "future_image",
      "label": "Future Background Image"
    },
    {
      "type": "color",
      "id": "future_text_color",
      "label": "Future Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "future_overlay_color",
      "label": "Future Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "future_overlay_opacity",
      "label": "Future Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "%"
    }
  ],
  "blocks": [
    {
      "type": "value_card",
      "name": "Value Card",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image",
          "info": "Upload a small icon (ideally 80x80px or SVG)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Innovation"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "We constantly strive to push the boundaries of design and technology."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Values + Future",
      "blocks": [
        {
          "type": "value_card",
          "settings": {
            "title": "Innovation",
            "description": "We constantly strive to push the boundaries of design and technology. We embrace change, and are always in search of new, improved methods and products to serve our customers better."
          }
        },
        {
          "type": "value_card",
          "settings": {
            "title": "Quality",
            "description": "We are committed to maintaining the highest quality standards in every product we offer. Each laundry rack is the result of meticulous design, rigorous testing, and premium materials."
          }
        },
        {
          "type": "value_card",
          "settings": {
            "title": "Sustainability",
            "description": "We acknowledge our role in preserving the environment and are dedicated to implementing sustainable practices in our operations."
          }
        },
        {
          "type": "value_card",
          "settings": {
            "title": "Customer Focus",
            "description": "Your satisfaction is our priority. We work tirelessly to ensure that our products and services meet and exceed your expectations."
          }
        }
      ]
    }
  ]
}
{% endschema %}
