{% comment %}
  Nuracom Landing — "Why people buy this"
  Icon grid hitting the real buying triggers immediately after the hero.
  Install to: sections/landing-why-buy.liquid
{% endcomment %}

<style>
  #lp-why-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 90px 24px;
  }

  #lp-why-{{ section.id }} .lp-why__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  #lp-why-{{ section.id }} .lp-why__header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 60px;
  }

  #lp-why-{{ section.id }} .lp-why__eyebrow {
    font-size: 12px;
    letter-spacing: 2.4px;
    text-transform: uppercase;
    font-weight: 700;
    color: {{ section.settings.accent_color }};
    margin: 0 0 14px;
  }

  #lp-why-{{ section.id }} .lp-why__heading {
    font-size: clamp(28px, 3.8vw, 44px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.4px;
    margin: 0 0 16px;
  }

  #lp-why-{{ section.id }} .lp-why__subheading {
    font-size: 17px;
    line-height: 1.6;
    opacity: 0.75;
    margin: 0;
  }

  #lp-why-{{ section.id }} .lp-why__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  #lp-why-{{ section.id }} .lp-why__card {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.card_border }};
    border-radius: 14px;
    padding: 32px 28px;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  #lp-why-{{ section.id }} .lp-why__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(16,26,50,0.08);
    border-color: {{ section.settings.accent_color }};
  }

  #lp-why-{{ section.id }} .lp-why__icon {
    width: 54px;
    height: 54px;
    border-radius: 14px;
    background: {{ section.settings.icon_bg }};
    color: {{ section.settings.accent_color }};
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    font-size: 26px;
  }

  #lp-why-{{ section.id }} .lp-why__card h3 {
    font-size: 19px;
    font-weight: 700;
    line-height: 1.25;
    margin: 0 0 8px;
  }

  #lp-why-{{ section.id }} .lp-why__card p {
    font-size: 15px;
    line-height: 1.55;
    opacity: 0.78;
    margin: 0;
  }

  @media (max-width: 900px) {
    #lp-why-{{ section.id }} .lp-why__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    #lp-why-{{ section.id }} {
      padding: 60px 18px;
    }
    #lp-why-{{ section.id }} .lp-why__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    #lp-why-{{ section.id }} .lp-why__card {
      padding: 26px 22px;
    }
  }
</style>

<section id="lp-why-{{ section.id }}">
  <div class="lp-why__inner">
    <div class="lp-why__header">
      {% if section.settings.eyebrow != blank %}
        <p class="lp-why__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="lp-why__heading">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="lp-why__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="lp-why__grid">
      {% for block in section.blocks %}
        <div class="lp-why__card" {{ block.shopify_attributes }}>
          <div class="lp-why__icon">{{ block.settings.icon }}</div>
          <h3>{{ block.settings.title }}</h3>
          {% if block.settings.text != blank %}
            <p>{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Landing — Why Buy",
  "tag": "section",
  "class": "landing-why-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The real reasons" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Australians are upgrading to Nuracom" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Six things that turn an interesting gadget into an obvious upgrade." },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#101a32" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#866653" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#fafaf8" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#eceae4" },
    { "type": "color", "id": "icon_bg", "label": "Icon background", "default": "#f3ede6" }
  ],
  "blocks": [
    {
      "type": "reason",
      "name": "Buying reason",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji or short text)", "default": "☁️" },
        { "type": "text", "id": "title", "label": "Title", "default": "Dry indoors, rain or shine" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Never plan washing around the weather again — dry anywhere, any time." }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Landing — Why Buy",
      "blocks": [
        { "type": "reason", "settings": { "icon": "☁️", "title": "Dry indoors, rain or shine", "text": "Never plan washing around the weather again — dry anywhere, any time." } },
        { "type": "reason", "settings": { "icon": "⚡", "title": "Faster than line drying", "text": "Heated airflow and elevated positioning dry clothes up to 3× faster than a line." } },
        { "type": "reason", "settings": { "icon": "💰", "title": "Under $1 per drying cycle", "text": "A full 2-hour cycle costs 57¢ on Breeze and Aero, 64¢ on Stratos — roughly a third of what a tumble dryer charges you per load." } },
        { "type": "reason", "settings": { "icon": "📐", "title": "Save floor space", "text": "Lifts out of the way when not in use — your laundry stays clean and functional." } },
        { "type": "reason", "settings": { "icon": "💡", "title": "Premium lighting and smart controls", "text": "Built-in lighting, remote control, and automation that actually feels premium." } },
        { "type": "reason", "settings": { "icon": "🏡", "title": "Designed for modern homes", "text": "Low-profile ceiling finish that looks intentional in renovations and new builds." } }
      ]
    }
  ]
}
{% endschema %}
