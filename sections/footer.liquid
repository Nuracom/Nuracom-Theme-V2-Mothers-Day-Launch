  #nuracom-footer-{{ section.id }} .nuracom-footer__main-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 48px;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__brand {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__logo img {
    max-width: 140px;
    height: auto;
    display: block;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__wordmark {
    font-size: 24px;
