    color: #fff;
    border-color: {{ section.settings.accent_color }};
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__btn--primary:hover {
    transform: translateY(-2px);
    filter: brightness(1.08);
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__btn--ghost {
    background: transparent;
    color: {{ section.settings.heading_color }};
    border-color: {{ section.settings.divider_color }};
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__btn--ghost:hover {
    transform: translateY(-2px);
    border-color: {{ section.settings.accent_color }};
    color: {{ section.settings.accent_color }};
  }

