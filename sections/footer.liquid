    text-underline-offset: 3px;
  }

  #nuracom-footer-{{ section.id }} a.nuracom-footer__contact-item:hover {
    color: {{ section.settings.accent_color }};
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__contact-item:hover {
    color: {{ section.settings.accent_color }};
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__contact-item svg,
  #nuracom-footer-{{ section.id }} .nuracom-footer__hours svg {
