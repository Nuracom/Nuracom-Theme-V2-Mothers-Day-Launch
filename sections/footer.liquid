  #nuracom-footer-{{ section.id }} .nuracom-footer__col-title {
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
    margin: 0 0 18px;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__col-links {
