  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: {{ section.settings.accent_color }};
    text-decoration: none;
    font-size: 15px;
    font-weight: 700;
