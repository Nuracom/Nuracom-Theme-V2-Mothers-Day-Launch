  #nuracom-footer-{{ section.id }} .nuracom-footer__tagline {
    text-align: center;
    padding: 54px 32px;
    border-bottom: 1px solid {{ section.settings.divider_color }};
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__heading {
    font-size: clamp(24px, 3.4vw, 36px);
    font-weight: 800;
    line-height: 1.15;
