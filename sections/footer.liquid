  #nuracom-footer-{{ section.id }} .nuracom-footer__legal-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__copy {
    margin: 0;
    font-size: 12.5px;
    opacity: 0.65;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__legal-links {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__legal-links a {
    color: {{ section.settings.text_color }};
    text-decoration: none;
    font-size: 12.5px;
    opacity: 0.65;
    transition: opacity 0.2s ease, color 0.2s ease;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__legal-links a:hover {
    opacity: 1;
    color: {{ section.settings.accent_color }};
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__country {
    font-size: 12px;
    opacity: 0.55;
    letter-spacing: 0.5px;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 960px) {
    #nuracom-footer-{{ section.id }} .nuracom-footer__main-inner {
      grid-template-columns: 1fr 1fr;
      gap: 36px;
    }
    #nuracom-footer-{{ section.id }} .nuracom-footer__brand {
      grid-column: 1 / -1;
    }
    #nuracom-footer-{{ section.id }} .nuracom-footer__process-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    #nuracom-footer-{{ section.id }} .nuracom-footer__warranty {
