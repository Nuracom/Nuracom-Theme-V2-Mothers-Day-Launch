  #nuracom-footer-{{ section.id }} .nuracom-footer__col-links a {
    color: {{ section.settings.text_color }};
    text-decoration: none;
    font-size: 14px;
    line-height: 1.5;
    transition: color 0.2s ease;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__col-links a:hover {
    color: {{ section.settings.accent_color }};
  }

  /* ===== BAND 4: LEGAL ===== */
  #nuracom-footer-{{ section.id }} .nuracom-footer__legal {
    padding: 24px 32px;
    background: {{ section.settings.legal_bg }};
