{% comment %}
  Nuracom Footer — Premium, Trust-Heavy
  4-band layout: (1) Warranty & Support trust block, (2) Tagline CTA,
  (3) Link columns + contact + socials, (4) Legal bar.
  Matches landing page brand (#101a32 navy, #866653 brown, #C69A7B accent).
{% endcomment %}

<footer class="nuracom-footer" id="nuracom-footer-{{ section.id }}">

  {%- comment -%} ===== BAND 1: WARRANTY & SUPPORT ===== {%- endcomment -%}
  {% if section.settings.show_warranty_band %}
    <div class="nuracom-footer__warranty">
      <div class="nuracom-footer__warranty-inner">

        <div class="nuracom-footer__warranty-header">
          {% if section.settings.warranty_eyebrow != blank %}
            <p class="nuracom-footer__eyebrow">{{ section.settings.warranty_eyebrow }}</p>
          {% endif %}
          <h2 class="nuracom-footer__warranty-heading">{{ section.settings.warranty_heading }}</h2>
          {% if section.settings.warranty_sub != blank %}
            <p class="nuracom-footer__warranty-sub">{{ section.settings.warranty_sub }}</p>
          {% endif %}
        </div>

        <div class="nuracom-footer__tiers">
          <div class="nuracom-footer__tier">
            <div class="nuracom-footer__tier-icon">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
            </div>
            <p class="nuracom-footer__tier-years">{{ section.settings.tier_1_years }}</p>
            <p class="nuracom-footer__tier-label">{{ section.settings.tier_1_label }}</p>
            {% if section.settings.tier_1_note != blank %}
              <p class="nuracom-footer__tier-note">{{ section.settings.tier_1_note }}</p>
            {% endif %}
          </div>
          <div class="nuracom-footer__tier">
            <div class="nuracom-footer__tier-icon">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
              </svg>
            </div>
            <p class="nuracom-footer__tier-years">{{ section.settings.tier_2_years }}</p>
            <p class="nuracom-footer__tier-label">{{ section.settings.tier_2_label }}</p>
            {% if section.settings.tier_2_note != blank %}
              <p class="nuracom-footer__tier-note">{{ section.settings.tier_2_note }}</p>
            {% endif %}
          </div>
          <div class="nuracom-footer__tier">
            <div class="nuracom-footer__tier-icon">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>
              </svg>
            </div>
            <p class="nuracom-footer__tier-years">{{ section.settings.tier_3_years }}</p>
            <p class="nuracom-footer__tier-label">{{ section.settings.tier_3_label }}</p>
            {% if section.settings.tier_3_note != blank %}
              <p class="nuracom-footer__tier-note">{{ section.settings.tier_3_note }}</p>
            {% endif %}
          </div>
        </div>

        <div class="nuracom-footer__process">
          <p class="nuracom-footer__process-title">{{ section.settings.process_title }}</p>
          <div class="nuracom-footer__process-grid">
            <div class="nuracom-footer__step">
              <div class="nuracom-footer__step-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
              </div>
              <p class="nuracom-footer__step-text">{{ section.settings.step_1 }}</p>
            </div>
            <div class="nuracom-footer__step">
              <div class="nuracom-footer__step-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="9" y1="15" x2="15" y2="15"/>
                </svg>
              </div>
              <p class="nuracom-footer__step-text">{{ section.settings.step_2 }}</p>
            </div>
            <div class="nuracom-footer__step">
              <div class="nuracom-footer__step-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="23 7 16 12 23 17 23 7"/>
                  <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
                </svg>
              </div>
              <p class="nuracom-footer__step-text">{{ section.settings.step_3 }}</p>
            </div>
            <div class="nuracom-footer__step">
              <div class="nuracom-footer__step-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
              </div>
              <p class="nuracom-footer__step-text">{{ section.settings.step_4 }}</p>
            </div>
          </div>
        </div>

        <div class="nuracom-footer__warranty-ctas">
          {% if section.settings.warranty_cta_text != blank and section.settings.warranty_cta_url != blank %}
            <a href="{{ section.settings.warranty_cta_url }}" class="nuracom-footer__btn nuracom-footer__btn--primary">
              {{ section.settings.warranty_cta_text }}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.account_cta_text != blank and section.settings.account_cta_url != blank %}
            <a href="{{ section.settings.account_cta_url }}" class="nuracom-footer__btn nuracom-footer__btn--ghost">
              {{ section.settings.account_cta_text }}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          {% endif %}
        </div>

      </div>
    </div>
  {% endif %}

  {%- comment -%} ===== BAND 2: TAGLINE CTA ===== {%- endcomment -%}
  {% if section.settings.show_tagline_band and section.settings.heading != blank %}
    <div class="nuracom-footer__tagline">
      <h2 class="nuracom-footer__heading">{{ section.settings.heading }}</h2>
      {% if section.settings.cta_text != blank %}
        <a href="{{ section.settings.cta_url }}" class="nuracom-footer__cta">
          {{ section.settings.cta_text }} <span class="nuracom-footer__cta-arrow">&rsaquo;</span>
        </a>
      {% endif %}
    </div>
  {% endif %}

  {%- comment -%} ===== BAND 3: MAIN FOOTER ===== {%- endcomment -%}
  <div class="nuracom-footer__main">
    <div class="nuracom-footer__main-inner">

      {%- comment -%} Brand column {%- endcomment -%}
      <div class="nuracom-footer__brand">
        {% if section.settings.logo != blank %}
          <div class="nuracom-footer__logo">
            <img src="{{ section.settings.logo | image_url: width: 300 }}" alt="{{ shop.name | escape }}" loading="lazy">
          </div>
        {% else %}
          <div class="nuracom-footer__wordmark">{{ shop.name }}</div>
        {% endif %}

        {% if section.settings.brand_blurb != blank %}
          <p class="nuracom-footer__brand-blurb">{{ section.settings.brand_blurb }}</p>
        {% endif %}

        <div class="nuracom-footer__contact">
          {% if section.settings.email != blank %}
            <a href="mailto:{{ section.settings.email }}" class="nuracom-footer__contact-item" title="Send us an email">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <span>{{ section.settings.email }}</span>
            </a>
          {% endif %}
          {% if section.settings.phone != blank %}
            <a href="tel:{{ section.settings.phone | remove: ' ' }}" class="nuracom-footer__contact-item" title="Call us">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
              <span>{{ section.settings.phone }}</span>
            </a>
          {% endif %}
          {% if section.settings.hours_line_1 != blank or section.settings.hours_line_2 != blank %}
            <div class="nuracom-footer__hours">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <div>
                {% if section.settings.hours_line_1 != blank %}<span>{{ section.settings.hours_line_1 }}</span>{% endif %}
                {% if section.settings.hours_line_2 != blank %}<span>{{ section.settings.hours_line_2 }}</span>{% endif %}
              </div>
            </div>
          {% endif %}
        </div>

        <div class="nuracom-footer__socials">
          {% if section.settings.social_facebook != blank %}
            <a href="{{ section.settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook" class="nuracom-footer__social-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9 8H6v4h3v12h5V12h3.642L18 8h-4V6.333C14 5.378 14.192 5 15.115 5H18V0h-3.808C10.596 0 9 1.583 9 4.615V8z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.social_instagram != blank %}
            <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram" class="nuracom-footer__social-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.social_tiktok != blank %}
            <a href="{{ section.settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok" class="nuracom-footer__social-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005.8 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1.84-.1z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.social_youtube != blank %}
            <a href="{{ section.settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube" class="nuracom-footer__social-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.social_email != blank %}
            <a href="mailto:{{ section.settings.social_email }}" aria-label="Email us" title="Email us" class="nuracom-footer__social-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M0 3v18h24V3H0zm21.518 2L12 12.713 2.482 5h19.036zM2 19V7.183l10 7.727 10-7.727V19H2z"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      {%- comment -%} Link columns {%- endcomment -%}
      {% if section.settings.col_1_title != blank or section.settings.menu_1 != blank %}
        <div class="nuracom-footer__col">
          {% if section.settings.col_1_title != blank %}
            <h4 class="nuracom-footer__col-title">{{ section.settings.col_1_title }}</h4>
          {% endif %}
          {% if section.settings.menu_1 != blank %}
            <ul class="nuracom-footer__col-links">
              {% for link in linklists[section.settings.menu_1].links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.col_2_title != blank or section.settings.menu_2 != blank %}
        <div class="nuracom-footer__col">
          {% if section.settings.col_2_title != blank %}
            <h4 class="nuracom-footer__col-title">{{ section.settings.col_2_title }}</h4>
          {% endif %}
          {% if section.settings.menu_2 != blank %}
            <ul class="nuracom-footer__col-links">
              {% for link in linklists[section.settings.menu_2].links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.col_3_title != blank or section.settings.menu_3 != blank %}
        <div class="nuracom-footer__col">
          {% if section.settings.col_3_title != blank %}
            <h4 class="nuracom-footer__col-title">{{ section.settings.col_3_title }}</h4>
          {% endif %}
          {% if section.settings.menu_3 != blank %}
            <ul class="nuracom-footer__col-links">
              {% for link in linklists[section.settings.menu_3].links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      {% endif %}

    </div>
  </div>

  {%- comment -%} ===== BAND 4: LEGAL BAR ===== {%- endcomment -%}
  <div class="nuracom-footer__legal">
    <div class="nuracom-footer__legal-inner">
      <p class="nuracom-footer__copy">{{ section.settings.copyright | default: '© ' | append: 'date' | date: "%Y" }}{% if section.settings.copyright == blank %} {{ shop.name }}. All rights reserved.{% endif %}</p>
      <div class="nuracom-footer__legal-links">
        {% if section.settings.legal_menu != blank %}
          {% for link in linklists[section.settings.legal_menu].links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        {% endif %}
      </div>
      {% if section.settings.country_badge != blank %}
        <span class="nuracom-footer__country">{{ section.settings.country_badge }}</span>
      {% endif %}
    </div>
  </div>

</footer>

<style>
  #nuracom-footer-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    font-family: inherit;
  }

  /* ===== BAND 1: WARRANTY ===== */
  #nuracom-footer-{{ section.id }} .nuracom-footer__warranty {
    background: {{ section.settings.warranty_bg }};
    padding: 72px 32px;
    border-bottom: 1px solid {{ section.settings.divider_color }};
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__warranty-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__warranty-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 44px;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__eyebrow {
    font-size: 11.5px;
    letter-spacing: 2.2px;
    text-transform: uppercase;
    font-weight: 700;
    color: {{ section.settings.accent_color }};
    margin: 0 0 14px;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__warranty-heading {
    font-size: clamp(26px, 3.2vw, 36px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.4px;
    margin: 0 0 14px;
    color: {{ section.settings.heading_color }};
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__warranty-sub {
    font-size: 15.5px;
    line-height: 1.6;
    margin: 0;
    opacity: 0.75;
  }

  /* Warranty tiers */
  #nuracom-footer-{{ section.id }} .nuracom-footer__tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-bottom: 44px;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__tier {
    text-align: center;
    padding: 28px 24px;
    background: {{ section.settings.tier_card_bg }};
    border: 1px solid {{ section.settings.divider_color }};
    border-radius: 14px;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__tier:hover {
    transform: translateY(-2px);
    border-color: {{ section.settings.accent_color }}77;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__tier-icon {
    width: 48px;
    height: 48px;
    margin: 0 auto 14px;
    border-radius: 50%;
    background: {{ section.settings.accent_color }}1f;
    color: {{ section.settings.accent_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__tier-years {
    font-size: 30px;
    font-weight: 800;
    line-height: 1;
    margin: 0 0 6px;
    color: {{ section.settings.heading_color }};
    letter-spacing: -0.4px;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__tier-label {
    font-size: 13.5px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin: 0 0 8px;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__tier-note {
    font-size: 13px;
    line-height: 1.5;
    margin: 0;
    opacity: 0.72;
  }

  /* Support process */
  #nuracom-footer-{{ section.id }} .nuracom-footer__process {
    background: {{ section.settings.tier_card_bg }};
    border: 1px solid {{ section.settings.divider_color }};
    border-radius: 14px;
    padding: 28px 28px;
    margin-bottom: 36px;
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__process-title {
    text-align: center;
    font-size: 12.5px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 700;
    margin: 0 0 22px;
    color: {{ section.settings.accent_color }};
  }

  #nuracom-footer-{{ section.id }} .nuracom-footer__process-grid {
    display: grid;
