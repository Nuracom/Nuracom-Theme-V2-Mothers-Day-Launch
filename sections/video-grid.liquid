{% comment %}
  Video Grid Section — 3x2 grid of videos with heading
  Add to: sections/video-grid.liquid
{% endcomment %}

<section class="vgrid-section" style="background-color: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="vgrid-container">

    {% if section.settings.subtitle != blank or section.settings.heading != blank or section.settings.subtext != blank %}
      <div class="vgrid-header">
        {% if section.settings.subtitle != blank %}
          <p class="vgrid-header__subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="vgrid-header__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subtext != blank %}
          <p class="vgrid-header__subtext">{{ section.settings.subtext }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="vgrid-grid">
      {% for block in section.blocks %}
        {% if block.type == 'video_item' %}
          <div class="vgrid-item" {{ block.shopify_attributes }}>
            <div class="vgrid-item__wrapper">

              {%- if block.settings.video != blank -%}
                {%- assign poster_url = '' -%}
                {%- if block.settings.cover_image != blank -%}
                  {%- assign poster_url = block.settings.cover_image | image_url: width: 600 -%}
                {%- elsif block.settings.video.preview_image -%}
                  {%- assign poster_url = block.settings.video.preview_image | image_url: width: 600 -%}
                {%- endif -%}
                {% if block.settings.autoplay %}
                  {{ block.settings.video | video_tag: image_size: '600x', autoplay: true, loop: true, muted: true, controls: false, class: 'vgrid-item__video' }}
                {% else %}
                  {{ block.settings.video | video_tag: image_size: '600x', autoplay: false, loop: false, muted: false, controls: true, class: 'vgrid-item__video' }}
                {% endif %}

              {%- elsif block.settings.video_url != blank -%}
                {%- if block.settings.cover_image != blank and block.settings.autoplay == false -%}
                  <div class="vgrid-item__cover" data-video-url="{{ block.settings.video_url | escape }}">
                    {{ block.settings.cover_image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'vgrid-item__poster' }}
                    <button class="vgrid-item__play" aria-label="Play video">
                      <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="24" cy="24" r="24" fill="rgba(0,0,0,0.5)"/>
                        <path d="M19 15L35 24L19 33V15Z" fill="#fff"/>
                      </svg>
                    </button>
                  </div>
                {%- else -%}
                  {%- assign embed_url = block.settings.video_url | external_video_url: autoplay: true, loop: true, mute: true -%}
                  <iframe
                    class="vgrid-item__iframe"
                    src="{{ embed_url }}"
                    allow="autoplay; encrypted-media"
                    allowfullscreen
                    frameborder="0"
                    loading="lazy"
                  ></iframe>
                {%- endif -%}

              {%- elsif block.settings.cover_image != blank -%}
                {{ block.settings.cover_image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'vgrid-item__poster' }}

              {%- else -%}
                <div class="vgrid-item__placeholder">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {%- endif -%}

              {% if block.settings.label != blank %}
                <span class="vgrid-item__label">{{ block.settings.label }}</span>
              {% endif %}

            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

<style>
  .vgrid-section {
    padding-left: 20px;
    padding-right: 20px;
  }

  .vgrid-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .vgrid-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .vgrid-header__subtitle {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #666;
    margin: 0 0 8px;
  }

  .vgrid-header__heading {
    font-size: 32px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .vgrid-header__subtext {
    font-size: 14px;
    color: #888;
    margin: 0;
  }

  .vgrid-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .vgrid-item__wrapper {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
    aspect-ratio: 9 / 12;
  }

  .vgrid-item__video,
  .vgrid-item__iframe,
  .vgrid-item__poster,
  .vgrid-item__wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .vgrid-item__iframe {
    border: none;
    position: absolute;
    top: 0;
    left: 0;
  }

  .vgrid-item__cover {
    width: 100%;
    height: 100%;
    position: relative;
    cursor: pointer;
  }

  .vgrid-item__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .vgrid-item__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: transform 0.2s ease;
  }

  .vgrid-item__play:hover {
    transform: translate(-50%, -50%) scale(1.1);
  }

  .vgrid-item__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f0f0f0;
  }

  .vgrid-item__placeholder svg {
    width: 60%;
    height: auto;
    opacity: 0.3;
  }

  .vgrid-item__label {
    position: absolute;
    bottom: 12px;
    left: 12px;
    font-size: 12px;
    color: #fff;
    background: rgba(0, 0, 0, 0.45);
    padding: 4px 10px;
    border-radius: 6px;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  @media (max-width: 768px) {
    .vgrid-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .vgrid-header__heading {
      font-size: 24px;
    }

    .vgrid-item__wrapper {
      border-radius: 8px;
    }
  }

  @media (max-width: 480px) {
    .vgrid-grid {
      gap: 8px;
    }

    .vgrid-item__label {
      font-size: 10px;
      bottom: 8px;
      left: 8px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Add playsinline to all videos for mobile autoplay support
    document.querySelectorAll('.vgrid-item__video').forEach(function (video) {
      video.setAttribute('playsinline', '');
      video.setAttribute('webkit-playsinline', '');
      // Force play if autoplay didn't trigger
      if (video.hasAttribute('autoplay')) {
        video.play().catch(function () {});
      }
    });

    document.querySelectorAll('.vgrid-item__cover[data-video-url]').forEach(function (cover) {
      cover.addEventListener('click', function () {
        var url = this.getAttribute('data-video-url');
        var wrapper = this.parentElement;
        var iframe = document.createElement('iframe');
        iframe.className = 'vgrid-item__iframe';
        iframe.setAttribute('src', url + (url.indexOf('?') > -1 ? '&' : '?') + 'autoplay=1');
        iframe.setAttribute('allow', 'autoplay; encrypted-media');
        iframe.setAttribute('allowfullscreen', '');
        iframe.setAttribute('frameborder', '0');
        iframe.style.position = 'absolute';
        iframe.style.top = '0';
        iframe.style.left = '0';
        iframe.style.width = '100%';
        iframe.style.height = '100%';
        wrapper.replaceChild(iframe, this);
      });
    });
  });
</script>

{% schema %}
{
  "name": "Video Grid",
  "tag": "section",
  "class": "video-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "OVER 2,000+ OF THEM HAVE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hassle-Free Laundry Days"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Join the community and tag us online at @nuracom"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "video_item",
      "name": "Video",
      "limit": 6,
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Shopify-hosted Video",
          "info": "Upload a video to Shopify (Settings > Files) and select it here."
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "External Video URL",
          "accept": ["youtube", "vimeo"],
          "info": "Used only if no Shopify video is selected above."
        },
        {
          "type": "image_picker",
          "id": "cover_image",
          "label": "Cover / Thumbnail Image",
          "info": "Displayed as the poster before the video plays."
        },
        {
          "type": "checkbox",
          "id": "autoplay",
          "label": "Autoplay (muted and looped)",
          "default": true
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label Overlay",
          "info": "e.g. @username - appears bottom-left"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Grid",
      "blocks": [
        { "type": "video_item" },
        { "type": "video_item" },
        { "type": "video_item" },
        { "type": "video_item" },
        { "type": "video_item" },
        { "type": "video_item" }
      ]
    }
  ]
}
{% endschema %}
