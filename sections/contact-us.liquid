{% comment %}
  Contact Us Section
  - Hero banner with heading
  - Subtitle text
  - 3x2 grid: image / address / image (top), call us / image / email (bottom)
  - All configurable via customizer
  Add to: sections/contact-us.liquid
{% endcomment %}

<section id="cu-{{ section.id }}">

  <!-- Hero Banner -->
  {% if section.settings.hero_heading != blank %}
    <div class="cu-hero">
      {% if section.settings.hero_image != blank %}
        {{ section.settings.hero_image | image_url: width: 1920 | image_tag: class: 'cu-hero__bg', alt: section.settings.hero_heading, loading: 'lazy' }}
      {% endif %}
      <div class="cu-hero__overlay"></div>
      <h1 class="cu-hero__heading">{{ section.settings.hero_heading }}</h1>
    </div>
  {% endif %}

  <!-- Subtitle -->
  {% if section.settings.subtitle != blank %}
    <p class="cu-subtitle">{{ section.settings.subtitle }}</p>
  {% endif %}

  <!-- Contact Grid -->
  <div class="cu-grid">

    <!-- Row 1: Image | Address | Image -->
    <div class="cu-grid__cell cu-grid__cell--img">
      {% if section.settings.image_1 != blank %}
        {{ section.settings.image_1 | image_url: width: 600 | image_tag: class: 'cu-grid__img', alt: 'Contact', loading: 'lazy' }}
      {% else %}
        <div class="cu-grid__placeholder"></div>
      {% endif %}
    </div>

    <div class="cu-grid__cell cu-grid__cell--info">
      <div class="cu-info">
        <svg class="cu-info__icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        <h3 class="cu-info__title">{{ section.settings.address_heading | default: 'Address' }}</h3>
        {% if section.settings.address_content != blank %}
          <div class="cu-info__text">{{ section.settings.address_content }}</div>
        {% endif %}
      </div>
    </div>

    <div class="cu-grid__cell cu-grid__cell--img">
      {% if section.settings.image_2 != blank %}
        {{ section.settings.image_2 | image_url: width: 600 | image_tag: class: 'cu-grid__img', alt: 'Contact', loading: 'lazy' }}
      {% else %}
        <div class="cu-grid__placeholder"></div>
      {% endif %}
    </div>

    <!-- Row 2: Call Us | Image | Email -->
    <div class="cu-grid__cell cu-grid__cell--info">
      <div class="cu-info">
        <svg class="cu-info__icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <h3 class="cu-info__title">{{ section.settings.phone_heading | default: 'Call Us' }}</h3>
        {% if section.settings.phone_content != blank %}
          <div class="cu-info__text">{{ section.settings.phone_content }}</div>
        {% endif %}
      </div>
    </div>

    <div class="cu-grid__cell cu-grid__cell--img">
      {% if section.settings.image_3 != blank %}
        {{ section.settings.image_3 | image_url: width: 600 | image_tag: class: 'cu-grid__img', alt: 'Contact', loading: 'lazy' }}
      {% else %}
        <div class="cu-grid__placeholder"></div>
      {% endif %}
    </div>

    <div class="cu-grid__cell cu-grid__cell--info">
      <div class="cu-info">
        <svg class="cu-info__icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="22,7 12,13 2,7"/>
        </svg>
        <h3 class="cu-info__title">{{ section.settings.email_heading | default: 'Email' }}</h3>
        {% if section.settings.email_content != blank %}
          <div class="cu-info__text">{{ section.settings.email_content }}</div>
        {% endif %}
      </div>
    </div>

  </div>

</section>

<style>
  #cu-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
  }

  /* ── Hero Banner ── */
  #cu-{{ section.id }} .cu-hero {
    position: relative;
    width: 100%;
    min-height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  #cu-{{ section.id }} .cu-hero__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #cu-{{ section.id }} .cu-hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ section.settings.hero_overlay_color }};
    opacity: {{ section.settings.hero_overlay_opacity | divided_by: 100.0 }};
  }

  #cu-{{ section.id }} .cu-hero__heading {
    position: relative;
    z-index: 1;
    font-size: 42px;
    font-weight: 700;
    font-style: italic;
    color: {{ section.settings.hero_text_color }};
    margin: 0;
    padding: 60px 20px;
    text-align: center;
  }

  /* ── Subtitle ── */
  #cu-{{ section.id }} .cu-subtitle {
    text-align: center;
    font-size: 15px;
    font-style: italic;
    color: {{ section.settings.subtitle_color }};
    max-width: 700px;
    margin: 40px auto;
    padding: 0 20px;
    line-height: 1.6;
  }

  /* ── Contact Grid ── */
  #cu-{{ section.id }} .cu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    max-width: 1100px;
    margin: 0 auto 60px;
    padding: 0 20px;
  }

  #cu-{{ section.id }} .cu-grid__cell {
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  #cu-{{ section.id }} .cu-grid__cell--img {
    position: relative;
  }

  #cu-{{ section.id }} .cu-grid__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #cu-{{ section.id }} .cu-grid__placeholder {
    width: 100%;
    height: 100%;
    background: #f0f0f0;
  }

  #cu-{{ section.id }} .cu-grid__cell--info {
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ section.settings.info_bg_color }};
  }

  #cu-{{ section.id }} .cu-info {
    text-align: center;
    padding: 24px 20px;
  }

  #cu-{{ section.id }} .cu-info__icon {
    display: block;
    margin: 0 auto 12px;
  }

  #cu-{{ section.id }} .cu-info__title {
    font-size: 22px;
    font-weight: 700;
    color: {{ section.settings.info_heading_color }};
    margin: 0 0 14px;
  }

  #cu-{{ section.id }} .cu-info__text {
    font-size: 14px;
    line-height: 1.7;
    color: {{ section.settings.info_text_color }};
  }

  #cu-{{ section.id }} .cu-info__text p {
    margin: 0 0 10px;
  }

  #cu-{{ section.id }} .cu-info__text p:last-child {
    margin-bottom: 0;
  }

  #cu-{{ section.id }} .cu-info__text a {
    color: #25D366;
    text-decoration: none;
    font-weight: 600;
  }

  #cu-{{ section.id }} .cu-info__text a:hover {
    text-decoration: underline;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    #cu-{{ section.id }} .cu-hero {
      min-height: 180px;
    }

    #cu-{{ section.id }} .cu-hero__heading {
      font-size: 30px;
      padding: 40px 20px;
    }

    #cu-{{ section.id }} .cu-grid {
      grid-template-columns: 1fr;
    }

    #cu-{{ section.id }} .cu-grid__cell {
      aspect-ratio: auto;
    }

    #cu-{{ section.id }} .cu-grid__cell--img {
      aspect-ratio: 16 / 10;
    }

    #cu-{{ section.id }} .cu-grid__cell--info {
      padding: 40px 20px;
    }
  }
</style>

{% schema %}
{
  "name": "Contact Us",
  "tag": "section",
  "class": "contact-us-section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Hero Banner"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero Heading",
      "default": "Contact Us"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    },
    {
      "type": "color",
      "id": "hero_text_color",
      "label": "Hero Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "hero_overlay_color",
      "label": "Hero Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "hero_overlay_opacity",
      "label": "Hero Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 45,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Subtitle"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle Text",
      "default": "Our team of customer service agents are here to answer your enquires between 10AM to 6PM daily!"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#444444"
    },
    {
      "type": "header",
      "content": "Grid Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1 (Top Left)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2 (Top Right)"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3 (Bottom Center)"
    },
    {
      "type": "header",
      "content": "Address"
    },
    {
      "type": "text",
      "id": "address_heading",
      "label": "Address Heading",
      "default": "Address"
    },
    {
      "type": "richtext",
      "id": "address_content",
      "label": "Address Details",
      "default": "<p>39 Woodlands Close<br>#05-66A Singapore 737856</p><p>1 Tampines North Dr 1<br>T-Space #01-27A S528559</p><p>33 Ubi Ave 3<br>Trivex #01-25 S408868</p>"
    },
    {
      "type": "header",
      "content": "Phone"
    },
    {
      "type": "text",
      "id": "phone_heading",
      "label": "Phone Heading",
      "default": "Call Us"
    },
    {
      "type": "richtext",
      "id": "phone_content",
      "label": "Phone Details",
      "default": "<p>+65 8886 0818<br><a href=\"https://wa.me/6588860818\">Whatsapp here</a></p>"
    },
    {
      "type": "header",
      "content": "Email"
    },
    {
      "type": "text",
      "id": "email_heading",
      "label": "Email Heading",
      "default": "Email"
    },
    {
      "type": "richtext",
      "id": "email_content",
      "label": "Email Details",
      "default": "<p>hello@nuracom.com.au</p>"
    },
    {
      "type": "header",
      "content": "Info Card Styling"
    },
    {
      "type": "color",
      "id": "info_bg_color",
      "label": "Info Card Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "info_heading_color",
      "label": "Info Heading Color",
      "default": "#101a32"
    },
    {
      "type": "color",
      "id": "info_text_color",
      "label": "Info Text Color",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#555555"
    }
  ],
  "presets": [
    {
      "name": "Contact Us"
    }
  ]
}
{% endschema %}
