{% comment %}
  Mosaic Feature Section
  - Centered heading + subtitle at top
  - 3-column mosaic grid:
    Row 1: image | text | image
    Row 2: text | image | text
  - Italic text, clean white background
  Add to: sections/mosaic-feature.liquid
{% endcomment %}

<section id="mosaic-{{ section.id }}">

  <!-- Header -->
  <div class="mosaic-header">
    {% if section.settings.heading != blank %}
      <h2 class="mosaic-title">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subtitle != blank %}
      <p class="mosaic-subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}
  </div>

  <!-- Mosaic Grid -->
  <div class="mosaic-grid">

    <!-- Row 1: Image | Text | Image -->
    <div class="mosaic-cell mosaic-cell--img">
      {% if section.settings.r1_image_1 != blank %}
        <img src="{{ section.settings.r1_image_1 | image_url: width: 800 }}" alt="" class="mosaic-img" loading="lazy">
      {% else %}
        <div class="mosaic-placeholder"></div>
      {% endif %}
    </div>

    <div class="mosaic-cell mosaic-cell--txt">
      {% if section.settings.r1_text != blank %}
        <div class="mosaic-text">{{ section.settings.r1_text }}</div>
      {% endif %}
    </div>

    <div class="mosaic-cell mosaic-cell--img">
      {% if section.settings.r1_image_2 != blank %}
        <img src="{{ section.settings.r1_image_2 | image_url: width: 800 }}" alt="" class="mosaic-img" loading="lazy">
      {% else %}
        <div class="mosaic-placeholder"></div>
      {% endif %}
    </div>

    <!-- Row 2: Text | Image | Text -->
    <div class="mosaic-cell mosaic-cell--txt">
      {% if section.settings.r2_text_1 != blank %}
        <div class="mosaic-text">{{ section.settings.r2_text_1 }}</div>
      {% endif %}
    </div>

    <div class="mosaic-cell mosaic-cell--img">
      {% if section.settings.r2_image != blank %}
        <img src="{{ section.settings.r2_image | image_url: width: 800 }}" alt="" class="mosaic-img" loading="lazy">
      {% else %}
        <div class="mosaic-placeholder"></div>
      {% endif %}
    </div>

    <div class="mosaic-cell mosaic-cell--txt">
      {% if section.settings.r2_text_2 != blank %}
        <div class="mosaic-text">{{ section.settings.r2_text_2 }}</div>
      {% endif %}
    </div>

  </div>
</section>

<style>
  #mosaic-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
  }

  /* ── Header ── */
  #mosaic-{{ section.id }} .mosaic-header {
    max-width: 900px;
    margin: 0 auto 40px;
    text-align: center;
  }

  #mosaic-{{ section.id }} .mosaic-title {
    font-size: 36px;
    font-weight: 700;
    color: #101a32;
    margin: 0 0 14px;
    line-height: 1.2;
  }

  #mosaic-{{ section.id }} .mosaic-subtitle {
    font-size: 15px;
    line-height: 1.65;
    color: #555;
    margin: 0;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Grid ── */
  #mosaic-{{ section.id }} .mosaic-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
  }

  /* ── Image Cell ── */
  #mosaic-{{ section.id }} .mosaic-cell--img {
    border-radius: 10px;
    overflow: hidden;
    min-height: 260px;
  }

  #mosaic-{{ section.id }} .mosaic-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #mosaic-{{ section.id }} .mosaic-placeholder {
    width: 100%;
    height: 100%;
    min-height: 260px;
    background: linear-gradient(135deg, #e8e8e8, #f5f5f5);
    border-radius: 10px;
  }

  /* ── Text Cell ── */
  #mosaic-{{ section.id }} .mosaic-cell--txt {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 28px 24px;
  }

  #mosaic-{{ section.id }} .mosaic-text {
    font-size: 14px;
    line-height: 1.75;
    color: #333;
    font-style: italic;
    font-weight: 600;
    text-align: center;
  }

  #mosaic-{{ section.id }} .mosaic-text p {
    margin: 0 0 10px;
  }

  #mosaic-{{ section.id }} .mosaic-text p:last-child {
    margin-bottom: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    #mosaic-{{ section.id }} .mosaic-grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    #mosaic-{{ section.id }} .mosaic-title {
      font-size: 28px;
    }

    #mosaic-{{ section.id }} .mosaic-cell--img {
      min-height: 220px;
    }

    #mosaic-{{ section.id }} .mosaic-cell--txt {
      padding: 20px 16px;
    }
  }
</style>

{% schema %}
{
  "name": "Mosaic Feature",
  "tag": "div",
  "class": "mosaic-feature-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hassle-Free OneTouch Lift"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "With NuraCom Stratos, clothes drying becomes a seamless and effortless experience that simplifies your daily routine."
    },
    {
      "type": "header",
      "content": "Row 1: Image | Text | Image"
    },
    {
      "type": "image_picker",
      "id": "r1_image_1",
      "label": "Row 1 — Left Image"
    },
    {
      "type": "richtext",
      "id": "r1_text",
      "label": "Row 1 — Center Text",
      "default": "<p>With our innovative pressure sensor technology, simply hold the descending rack gently to stop it in its tracks.</p>"
    },
    {
      "type": "image_picker",
      "id": "r1_image_2",
      "label": "Row 1 — Right Image"
    },
    {
      "type": "header",
      "content": "Row 2: Text | Image | Text"
    },
    {
      "type": "richtext",
      "id": "r2_text_1",
      "label": "Row 2 — Left Text",
      "default": "<p>Designed for effortless operation, NuraCom Stratos features a double-layer scissor-arm lifting frame that retracts and extends with ease, making it the perfect solution for busy households with frequent washloads.</p>"
    },
    {
      "type": "image_picker",
      "id": "r2_image",
      "label": "Row 2 — Center Image"
    },
    {
      "type": "richtext",
      "id": "r2_text_2",
      "label": "Row 2 — Right Text",
      "default": "<p>Once your clothes are hung up, a gentle upward push is all it takes to lift the rack and begin the drying process. This one-touch lifting feature streamlines your laundry experience, especially when your hands are full or in a hurry.</p>"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 60,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Mosaic Feature"
    }
  ]
}
{% endschema %}
