{% comment %}
  Nuracom Landing — Final CTA + Model Pick
  Closes the page with a strong promise, three model cards, and a no-risk trust line.
  Install to: sections/landing-final-cta.liquid
{% endcomment %}

<style>
  #lp-final-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 100px 24px 90px;
    position: relative;
    overflow: hidden;
  }

  #lp-final-{{ section.id }} .lp-final__bg-glow {
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 900px;
    background: radial-gradient(circle, {{ section.settings.accent_color }}22 0%, transparent 60%);
    pointer-events: none;
  }

  #lp-final-{{ section.id }} .lp-final__inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  #lp-final-{{ section.id }} .lp-final__header {
    text-align: center;
    max-width: 780px;
    margin: 0 auto 56px;
  }

  #lp-final-{{ section.id }} .lp-final__eyebrow {
    font-size: 12px;
    letter-spacing: 2.4px;
    text-transform: uppercase;
    font-weight: 700;
    color: {{ section.settings.accent_color }};
    margin: 0 0 14px;
  }

  #lp-final-{{ section.id }} .lp-final__heading {
    font-size: clamp(32px, 4.4vw, 52px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.5px;
    margin: 0 0 18px;
  }

  #lp-final-{{ section.id }} .lp-final__sub {
    font-size: 18px;
    line-height: 1.6;
    opacity: 0.82;
    margin: 0;
  }

  #lp-final-{{ section.id }} .lp-final__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    margin-bottom: 48px;
  }

  #lp-final-{{ section.id }} .lp-final__card {
    position: relative;
    background: {{ section.settings.card_bg }};
    color: {{ section.settings.card_text }};
    border: 1px solid {{ section.settings.border_color }};
    border-radius: 18px;
    padding: 32px 28px 30px;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  #lp-final-{{ section.id }} .lp-final__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 22px 50px rgba(16,26,50,0.22);
  }

  #lp-final-{{ section.id }} .lp-final__card--featured {
    background: {{ section.settings.accent_color }};
    color: #fff;
    border-color: {{ section.settings.accent_color }};
  }

  #lp-final-{{ section.id }} .lp-final__badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: #101a32;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 999px;
    white-space: nowrap;
  }

  #lp-final-{{ section.id }} .lp-final__card-image {
    aspect-ratio: 4/3;
    background: {{ section.settings.image_bg }};
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 20px;
  }

  #lp-final-{{ section.id }} .lp-final__card--featured .lp-final__card-image {
    background: rgba(255,255,255,0.15);
  }

  #lp-final-{{ section.id }} .lp-final__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #lp-final-{{ section.id }} .lp-final__model {
    font-size: 22px;
    font-weight: 800;
    margin: 0 0 6px;
    letter-spacing: -0.2px;
  }

  #lp-final-{{ section.id }} .lp-final__tagline {
    font-size: 14px;
    line-height: 1.45;
    margin: 0 0 14px;
    opacity: 0.8;
  }

  #lp-final-{{ section.id }} .lp-final__price {
    font-size: 28px;
    font-weight: 800;
    margin: 0 0 4px;
    letter-spacing: -0.5px;
  }

  #lp-final-{{ section.id }} .lp-final__price-note {
    font-size: 12.5px;
    opacity: 0.7;
    margin: 0 0 20px;
  }

  #lp-final-{{ section.id }} .lp-final__btn {
    display: block;
    text-align: center;
    padding: 14px 20px;
    border-radius: 999px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    margin-top: auto;
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  #lp-final-{{ section.id }} .lp-final__btn--primary {
    background: {{ section.settings.accent_color }};
    color: #fff;
  }

  #lp-final-{{ section.id }} .lp-final__card--featured .lp-final__btn--primary {
    background: #fff;
    color: {{ section.settings.accent_color }};
  }

  #lp-final-{{ section.id }} .lp-final__btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.05);
  }

  /* Reassurance row */
  #lp-final-{{ section.id }} .lp-final__reassurance {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 22px 32px;
    padding: 28px;
    background: {{ section.settings.reassurance_bg }};
    border-radius: 16px;
    text-align: center;
  }

  #lp-final-{{ section.id }} .lp-final__reassure-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-weight: 600;
  }

  #lp-final-{{ section.id }} .lp-final__reassure-item svg {
    color: {{ section.settings.accent_color }};
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    #lp-final-{{ section.id }} .lp-final__grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin-left: auto;
      margin-right: auto;
      margin-bottom: 40px;
    }
  }

  @media (max-width: 560px) {
    #lp-final-{{ section.id }} {
      padding: 70px 18px 60px;
    }
    #lp-final-{{ section.id }} .lp-final__reassurance {
      flex-direction: column;
      align-items: center;
      gap: 14px;
    }
  }
</style>

<section id="lp-final-{{ section.id }}">
  <div class="lp-final__bg-glow"></div>
  <div class="lp-final__inner">
    <div class="lp-final__header">
      {% if section.settings.eyebrow != blank %}
        <p class="lp-final__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="lp-final__heading">{{ section.settings.heading }}</h2>
      {% if section.settings.sub != blank %}
        <p class="lp-final__sub">{{ section.settings.sub }}</p>
      {% endif %}
    </div>

    <div class="lp-final__grid">
      {% for block in section.blocks %}
        {% if block.type == 'model' %}
          <div class="lp-final__card {% if block.settings.featured %}lp-final__card--featured{% endif %}" {{ block.shopify_attributes }}>
            {% if block.settings.badge != blank %}
              <span class="lp-final__badge">{{ block.settings.badge }}</span>
            {% endif %}
            <div class="lp-final__card-image">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 700 }}" alt="{{ block.settings.name | escape }}" loading="lazy">
              {% else %}
                {{ 'product-1' | placeholder_svg_tag }}
              {% endif %}
            </div>
            <h3 class="lp-final__model">{{ block.settings.name }}</h3>
            {% if block.settings.tagline != blank %}
              <p class="lp-final__tagline">{{ block.settings.tagline }}</p>
            {% endif %}
            <p class="lp-final__price">{{ block.settings.price }}</p>
            {% if block.settings.price_note != blank %}
              <p class="lp-final__price-note">{{ block.settings.price_note }}</p>
            {% endif %}
            <a href="{{ block.settings.link | default: '#' }}" class="lp-final__btn lp-final__btn--primary">
              {{ block.settings.btn_label | default: 'Shop now' }}
            </a>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="lp-final__reassurance">
      {% if section.settings.reassure_1 != blank %}
        <div class="lp-final__reassure-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          {{ section.settings.reassure_1 }}
        </div>
      {% endif %}
      {% if section.settings.reassure_2 != blank %}
        <div class="lp-final__reassure-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 3h15v13H1zM16 8h4l3 3v5h-7z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          {{ section.settings.reassure_2 }}
        </div>
      {% endif %}
      {% if section.settings.reassure_3 != blank %}
        <div class="lp-final__reassure-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 4v6h6"/><path d="M23 20v-6h-6"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
          {{ section.settings.reassure_3 }}
        </div>
      {% endif %}
      {% if section.settings.reassure_4 != blank %}
        <div class="lp-final__reassure-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          {{ section.settings.reassure_4 }}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Landing — Final CTA",
  "tag": "section",
  "class": "landing-final-cta-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Ready to upgrade your laundry?" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pick your Nuracom and stop fighting the weather" },
    { "type": "textarea", "id": "sub", "label": "Subheading", "default": "Three models, one promise: premium indoor drying that reclaims your floor space and your weekend. Free AU shipping, 2-year warranty, real human support." },
    { "type": "header", "content": "Reassurance row" },
    { "type": "text", "id": "reassure_1", "label": "Reassurance 1", "default": "2-Year Australian Warranty" },
    { "type": "text", "id": "reassure_2", "label": "Reassurance 2", "default": "Ships Free from AU Warehouse" },
    { "type": "text", "id": "reassure_3", "label": "Reassurance 3", "default": "30-Day Hassle-Free Returns" },
    { "type": "text", "id": "reassure_4", "label": "Reassurance 4", "default": "Real Local Support Team" },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#101a32" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#C69A7B" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#ffffff" },
    { "type": "color", "id": "card_text", "label": "Card text", "default": "#101a32" },
    { "type": "color", "id": "border_color", "label": "Card border", "default": "#e8e4dc" },
    { "type": "color", "id": "image_bg", "label": "Image placeholder bg", "default": "#f7f5f1" },
    { "type": "color", "id": "reassurance_bg", "label": "Reassurance bar bg", "default": "rgba(255,255,255,0.06)" }
  ],
  "blocks": [
    {
      "type": "model",
      "name": "Model card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Product image" },
        { "type": "text", "id": "name", "label": "Model name", "default": "Nuracom Aero" },
        { "type": "text", "id": "tagline", "label": "Tagline", "default": "Most popular — premium lighting + heated drying." },
        { "type": "text", "id": "price", "label": "Price", "default": "$1,299" },
        { "type": "text", "id": "price_note", "label": "Price note", "default": "Free AU shipping. Install from $150." },
        { "type": "text", "id": "btn_label", "label": "Button label", "default": "Shop Aero" },
        { "type": "url", "id": "link", "label": "Product URL" },
        { "type": "text", "id": "badge", "label": "Badge (e.g. Most Popular)" },
        { "type": "checkbox", "id": "featured", "label": "Highlight as featured", "default": false }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Landing — Final CTA",
      "blocks": [
        {
          "type": "model",
          "settings": {
            "name": "Nuracom Breeze",
            "tagline": "Our entry smart rack — ideal for studios and small laundries.",
            "price": "$899",
            "price_note": "Free AU shipping. Install from $150.",
            "btn_label": "Shop Breeze",
            "featured": false
          }
        },
        {
          "type": "model",
          "settings": {
            "name": "Nuracom Aero",
            "tagline": "Our most popular model — premium lighting and heated drying built in.",
            "price": "$1,299",
            "price_note": "Free AU shipping. Install from $150.",
            "btn_label": "Shop Aero",
            "badge": "Most Popular",
            "featured": true
          }
        },
        {
          "type": "model",
          "settings": {
            "name": "Nuracom Stratos",
            "tagline": "Top-spec with telescopic rails, ideal for larger families and premium homes.",
            "price": "$1,799",
            "price_note": "Free AU shipping. Install from $150.",
            "btn_label": "Shop Stratos",
            "featured": false
          }
        }
      ]
    }
  ]
}
{% endschema %}
