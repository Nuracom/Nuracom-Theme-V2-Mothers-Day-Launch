{% comment %}
  Nuracom Problem Agitation — Cements Belief #1 (this problem is costing me)
  Three problem cards in the prospect's own voice.
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    --brand-deep: {{ section.settings.brand_deep }};
    --brand-accent: {{ section.settings.brand_accent }};
    --navy: {{ section.settings.navy }};
    --cream: {{ section.settings.cream }};
    --warm-gray: {{ section.settings.warm_gray }};
    --text-secondary: {{ section.settings.text_secondary }};
    --text-muted: {{ section.settings.text_muted }};
    --white: {{ section.settings.white }};
    --radius: 12px;
    --max-width: 1120px;
    --section-pad: clamp(44px, 6vw, 80px);
  }
  #shopify-section-{{ section.id }} * { box-sizing: border-box; }
  #shopify-section-{{ section.id }} .nprob { padding: var(--section-pad) 0; background: {{ section.settings.bg_color }}; font-family: 'Inter', -apple-system, sans-serif; }
  #shopify-section-{{ section.id }} .nprob__container { max-width: var(--max-width); margin: 0 auto; padding: 0 24px; }
  #shopify-section-{{ section.id }} .nprob__intro { max-width: 680px; margin: 0 auto 60px; text-align: center; }
  #shopify-section-{{ section.id }} .nprob__kicker { font-size: 0.75rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--brand-accent); margin-bottom: 12px; display: block; }
  #shopify-section-{{ section.id }} .nprob__headline { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.2; color: var(--navy); margin: 0 0 20px; }
  #shopify-section-{{ section.id }} .nprob__sub { font-size: clamp(1.05rem, 1.5vw, 1.2rem); color: var(--text-secondary); line-height: 1.7; margin: 0 auto; max-width: 640px; }
  #shopify-section-{{ section.id }} .nprob__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  #shopify-section-{{ section.id }} .nprob__card { background: var(--cream); border-radius: var(--radius); padding: 36px 28px; position: relative; transition: transform 0.3s ease, box-shadow 0.3s ease; }
  #shopify-section-{{ section.id }} .nprob__card:hover { transform: translateY(-4px); box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
  #shopify-section-{{ section.id }} .nprob__card-icon { width: 52px; height: 52px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 20px; }
  #shopify-section-{{ section.id }} .nprob__card:nth-child(1) .nprob__card-icon { background: {{ section.settings.icon_bg_1 }}; }
  #shopify-section-{{ section.id }} .nprob__card:nth-child(2) .nprob__card-icon { background: {{ section.settings.icon_bg_2 }}; }
  #shopify-section-{{ section.id }} .nprob__card:nth-child(3) .nprob__card-icon { background: {{ section.settings.icon_bg_3 }}; }
  #shopify-section-{{ section.id }} .nprob__card-title { font-size: 1.15rem; font-weight: 700; color: var(--navy); margin: 0 0 12px; line-height: 1.3; }
  #shopify-section-{{ section.id }} .nprob__card-text { font-size: 0.95rem; color: var(--text-secondary); line-height: 1.7; margin: 0; }
  #shopify-section-{{ section.id }} .nprob__card-quote { font-style: italic; font-size: 0.9rem; color: var(--brand-deep); margin: 16px 0 0; padding-top: 16px; border-top: 1px solid var(--warm-gray); line-height: 1.6; }
  #shopify-section-{{ section.id }} .nprob__reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
  #shopify-section-{{ section.id }} .nprob__reveal.is-visible { opacity: 1; transform: translateY(0); }
  #shopify-section-{{ section.id }} .nprob__reveal--d1 { transition-delay: 0.1s; }
  #shopify-section-{{ section.id }} .nprob__reveal--d2 { transition-delay: 0.2s; }
  #shopify-section-{{ section.id }} .nprob__reveal--d3 { transition-delay: 0.3s; }

  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .nprob__grid { grid-template-columns: 1fr; max-width: 500px; margin: 0 auto; }
  }
</style>

<section class="nprob">
  <div class="nprob__container">
    <div class="nprob__intro nprob__reveal">
      {% if section.settings.kicker != blank %}
        <span class="nprob__kicker">{{ section.settings.kicker }}</span>
      {% endif %}
      <h2 class="nprob__headline">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="nprob__sub">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="nprob__grid">
      {% for block in section.blocks %}
        <div class="nprob__card nprob__reveal nprob__reveal--d{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="nprob__card-icon">{{ block.settings.icon }}</div>
          <h3 class="nprob__card-title">{{ block.settings.title }}</h3>
          <p class="nprob__card-text">{{ block.settings.description | newline_to_br }}</p>
          {% if block.settings.quote != blank %}
            <p class="nprob__card-quote">&ldquo;{{ block.settings.quote }}&rdquo;</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
  (function() {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;
    var els = root.querySelectorAll('.nprob__reveal');
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
    els.forEach(function(el) { io.observe(el); });
  })();
</script>

{% schema %}
{
  "name": "Problem & Agitation",
  "tag": "section",
  "class": "nuracom-problem-agitation-section",
  "settings": [
    { "type": "header", "content": "Section intro" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Sound familiar?" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Three Laundry Problems Every Australian Knows" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "You've been tolerating these for years. But they're costing you more than you think." },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "brand_deep", "label": "Brand deep (quote text)", "default": "#5E0404" },
    { "type": "color", "id": "brand_accent", "label": "Kicker colour", "default": "#a8321a" },
    { "type": "color", "id": "navy", "label": "Navy (headings)", "default": "#101a32" },
    { "type": "color", "id": "cream", "label": "Card background", "default": "#f8f5f1" },
    { "type": "color", "id": "warm_gray", "label": "Quote divider line", "default": "#e8e3dd" },
    { "type": "color", "id": "text_secondary", "label": "Body text", "default": "#555555" },
    { "type": "color", "id": "text_muted", "label": "Muted text", "default": "#888888" },
    { "type": "color", "id": "white", "label": "White", "default": "#ffffff" },
    { "type": "color", "id": "icon_bg_1", "label": "Card 1 icon background", "default": "#fef2f2" },
    { "type": "color", "id": "icon_bg_2", "label": "Card 2 icon background", "default": "#fff7ed" },
    { "type": "color", "id": "icon_bg_3", "label": "Card 3 icon background", "default": "#fefce8" }
  ],
  "blocks": [
    {
      "type": "problem_card",
      "name": "Problem Card",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "⊗" },
        { "type": "text", "id": "title", "label": "Title", "default": "Problem title" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Explain the problem in the prospect's own language." },
        { "type": "textarea", "id": "quote", "label": "Customer quote (optional)", "default": "A short quote in their voice." }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Problem & Agitation",
      "blocks": [
        { "type": "problem_card", "settings": { "icon": "⊗", "title": "Your Laundry Schedule Is Controlled by the Weather", "description": "You check the forecast before every wash. You rearrange your day around drying windows. And when rain hits mid-dry, you're rewashing a full load that now smells like damp towels. Your time is being stolen by something completely out of your control.", "quote": "I'm so sick of planning my entire week around whether it's going to rain." } },
        { "type": "problem_card", "settings": { "icon": "⚡", "title": "The Dryer Costs a Fortune (And Ruins Your Clothes)", "description": "At $2–$3 per load, your tumble dryer is quietly draining hundreds of dollars a year. And the clothes it doesn't shrink, it fades. You're paying premium prices for a machine that actively damages your wardrobe. That's not a solution — it's a tax on bad weather.", "quote": "The dryer shrunk my favourite jumper and I'm still annoyed about it. But what choice do I have?" } },
        { "type": "problem_card", "settings": { "icon": "💨", "title": "Damp Clothes, Damp House, Damp Mood", "description": "Clothes draped over every surface. A clothes horse blocking the hallway. That faint musty smell that never quite leaves. Indoor drying without a proper system doesn't just look bad — it's creating humidity that feeds mould, triggers allergies, and makes your home uncomfortable.", "quote": "Our apartment looks like a refugee camp half the week with clothes hanging everywhere." } }
      ]
    }
  ]
}
{% endschema %}
