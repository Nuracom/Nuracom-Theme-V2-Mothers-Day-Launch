{% comment %}
  Feature Showcase Section
  - Alternating text + image rows (text-left/image-right, then image-left/text-right)
  - Each row: heading, description, optional callout (icon + title + subtitle)
  - Rows alternate layout automatically
  - Italic headings, clean spacing
  Add to: sections/feature-showcase.liquid
{% endcomment %}

<section id="fsc-{{ section.id }}">
  {% for block in section.blocks %}
    <div class="fsc-row{% cycle ' fsc-row--normal', ' fsc-row--reversed' %}" {{ block.shopify_attributes }}>

      <!-- Text Side -->
      <div class="fsc-text">
        {% if block.settings.heading != blank %}
          <h2 class="fsc-heading">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.description != blank %}
          <div class="fsc-description">{{ block.settings.description }}</div>
        {% endif %}

        {% if block.settings.callout_title != blank %}
          <div class="fsc-callout">
            {% if block.settings.callout_icon != blank %}
              <div class="fsc-callout__icon">
                <img
                  src="{{ block.settings.callout_icon | image_url: width: 60 }}"
                  alt="{{ block.settings.callout_title | escape }}"
                  width="28"
                  height="28"
                  loading="lazy"
                >
              </div>
            {% else %}
              <div class="fsc-callout__icon fsc-callout__icon--default">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
            {% endif %}
            <div>
              <p class="fsc-callout__title">{{ block.settings.callout_title }}</p>
              {% if block.settings.callout_text != blank %}
                <p class="fsc-callout__text">{{ block.settings.callout_text }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      </div>

      <!-- Image Side -->
      <div class="fsc-image">
        {% if block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.heading | escape }}"
            class="fsc-image__img"
            loading="lazy"
          >
        {% else %}
          <div class="fsc-image__placeholder"></div>
        {% endif %}
      </div>

    </div>
  {% endfor %}
</section>

<style>
  #fsc-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  /* ── Row ── */
  #fsc-{{ section.id }} .fsc-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    max-width: 1200px;
    margin: 0 auto;
    min-height: 320px;
  }

  #fsc-{{ section.id }} .fsc-row + .fsc-row {
    border-top: 1px solid #eee;
  }

  #fsc-{{ section.id }} .fsc-row--reversed .fsc-text {
    order: 2;
  }

  #fsc-{{ section.id }} .fsc-row--reversed .fsc-image {
    order: 1;
  }

  /* ── Text ── */
  #fsc-{{ section.id }} .fsc-text {
    padding: 48px 44px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #fsc-{{ section.id }} .fsc-heading {
    font-size: 28px;
    font-weight: 700;
    color: #101a32;
    margin: 0 0 18px;
    line-height: 1.25;
    font-style: italic;
  }

  #fsc-{{ section.id }} .fsc-description {
    font-size: 15px;
    line-height: 1.75;
    color: #444;
    font-style: italic;
    margin: 0 0 24px;
  }

  #fsc-{{ section.id }} .fsc-description p {
    margin: 0 0 12px;
  }

  #fsc-{{ section.id }} .fsc-description p:last-child {
    margin-bottom: 0;
  }

  /* ── Callout ── */
  #fsc-{{ section.id }} .fsc-callout {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin-top: 4px;
  }

  #fsc-{{ section.id }} .fsc-callout__icon {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
  }

  #fsc-{{ section.id }} .fsc-callout__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  #fsc-{{ section.id }} .fsc-callout__icon--default {
    background: #e8f0fe;
    color: #1a73e8;
  }

  #fsc-{{ section.id }} .fsc-callout__title {
    font-size: 15px;
    font-weight: 700;
    color: #101a32;
    margin: 0 0 4px;
  }

  #fsc-{{ section.id }} .fsc-callout__text {
    font-size: 14px;
    line-height: 1.6;
    color: #555;
    margin: 0;
    font-style: italic;
  }

  /* ── Image ── */
  #fsc-{{ section.id }} .fsc-image {
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
  }

  #fsc-{{ section.id }} .fsc-image__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #fsc-{{ section.id }} .fsc-image__placeholder {
    width: 100%;
    min-height: 320px;
    background: linear-gradient(135deg, #e8e8e8 0%, #f5f5f5 100%);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    #fsc-{{ section.id }} .fsc-row {
      grid-template-columns: 1fr;
    }

    #fsc-{{ section.id }} .fsc-row--reversed .fsc-text {
      order: 1;
    }

    #fsc-{{ section.id }} .fsc-row--reversed .fsc-image {
      order: 2;
    }

    #fsc-{{ section.id }} .fsc-text {
      padding: 32px 24px;
    }

    #fsc-{{ section.id }} .fsc-heading {
      font-size: 24px;
    }

    #fsc-{{ section.id }} .fsc-image {
      min-height: 240px;
    }
  }
</style>

{% schema %}
{
  "name": "Feature Showcase",
  "tag": "div",
  "class": "feature-showcase-section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "feature_row",
      "name": "Feature Row",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "A True Sense of Cleanliness"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>NuraCom Stratos employs the latest in UV light technology to harness its sterilising power, effectively eliminating any remaining bacteria and viruses on your clothes.</p>"
        },
        {
          "type": "header",
          "content": "Callout (optional)"
        },
        {
          "type": "image_picker",
          "id": "callout_icon",
          "label": "Callout Icon"
        },
        {
          "type": "text",
          "id": "callout_title",
          "label": "Callout Title"
        },
        {
          "type": "text",
          "id": "callout_text",
          "label": "Callout Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Showcase",
      "blocks": [
        {
          "type": "feature_row",
          "settings": {
            "heading": "A True Sense of Cleanliness",
            "description": "<p>NuraCom Stratos employs the latest in UV light technology to harness its sterilising power, effectively eliminating any remaining bacteria and viruses on your clothes. The technology penetrates the cell walls of these microorganisms and destroys their DNA, leaving your garments impeccably clean and germ-free.</p>",
            "callout_title": "Auto Human Detection",
            "callout_text": "The inbuilt safety mechanism automatically turns the UV lamp off when it detects a person in the area, preventing potential harm."
          }
        },
        {
          "type": "feature_row",
          "settings": {
            "heading": "Ultrasonic Brilliance",
            "description": "<p>Dust mites are a prevalent household problem known for causing allergies and respiratory complications. Addressing this common health threat, our ingenious ultrasonic wave technology emits robust waves that permeate fabrics, effectively destroying and preventing dust mites from breeding and thriving on your clothes.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
