{% comment %}
  Feature Grid Section — 2x2 grid with images, headings, and descriptions
  Add to: sections/feature-grid.liquid
{% endcomment %}

<section class="fgrid-section" style="background-color: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="fgrid-container">

    {% if section.settings.heading != blank or section.settings.subtext != blank %}
      <div class="fgrid-header">
        {% if section.settings.heading != blank %}
          <h2 class="fgrid-header__heading" style="color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subtext != blank %}
          <p class="fgrid-header__subtext" style="color: {{ section.settings.text_color }};">{{ section.settings.subtext }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="fgrid-grid">
      {% for block in section.blocks %}
        {% if block.type == 'feature_card' %}
          <div class="fgrid-card" style="background-color: {{ block.settings.card_bg_color }}; border-radius: {{ section.settings.card_radius }}px;" {{ block.shopify_attributes }}>

            <div class="fgrid-card__media-wrap" style="border-radius: {{ section.settings.card_radius | minus: 4 }}px;">
              {%- if block.settings.media_type == 'video' and block.settings.video != blank -%}
                <div class="fgrid-card__video">
                  {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'fgrid-card__media' }}
                </div>
              {%- elsif block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'fgrid-card__media' }}
              {%- else -%}
                <div class="fgrid-card__placeholder">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {%- endif -%}
            </div>

            <div class="fgrid-card__content">
              {% if block.settings.title != blank %}
                <h3 class="fgrid-card__title" style="color: {{ block.settings.title_color }};">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="fgrid-card__desc" style="color: {{ block.settings.desc_color }};">{{ block.settings.description }}</div>
              {% endif %}
            </div>

          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

<style>
  .fgrid-section {
    padding-left: 20px;
    padding-right: 20px;
  }

  .fgrid-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .fgrid-header {
    text-align: center;
    margin-bottom: 36px;
  }

  .fgrid-header__heading {
    font-size: 32px;
    font-weight: 700;
    margin: 0 0 10px;
    line-height: 1.2;
  }

  .fgrid-header__subtext {
    font-size: 14px;
    font-style: italic;
    margin: 0;
    opacity: 0.8;
  }

  .fgrid-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .fgrid-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .fgrid-card__media-wrap {
    margin: 12px 12px 0;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    position: relative;
  }

  .fgrid-card__media-wrap img,
  .fgrid-card__media-wrap video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .fgrid-card__video {
    width: 100%;
    height: 100%;
  }

  .fgrid-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #2a2a3d;
  }

  .fgrid-card__placeholder svg {
    width: 50%;
    height: auto;
    opacity: 0.2;
  }

  .fgrid-card__content {
    padding: 20px 20px 24px;
  }

  .fgrid-card__title {
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .fgrid-card__desc {
    font-size: 13px;
    line-height: 1.6;
    margin: 0;
    opacity: 0.85;
  }

  .fgrid-card__desc p {
    margin: 0 0 10px;
  }

  .fgrid-card__desc p:last-child {
    margin-bottom: 0;
  }

  .fgrid-card__desc ul,
  .fgrid-card__desc ol {
    margin: 8px 0 10px;
    padding-left: 20px;
  }

  .fgrid-card__desc li {
    margin-bottom: 4px;
  }

  .fgrid-card__desc li:last-child {
    margin-bottom: 0;
  }

  .fgrid-card__desc strong {
    font-weight: 700;
  }

  .fgrid-card__desc a {
    color: inherit;
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .fgrid-grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto;
    }

    .fgrid-header__heading {
      font-size: 26px;
    }
  }

  @media (max-width: 480px) {
    .fgrid-card__content {
      padding: 16px 16px 20px;
    }

    .fgrid-card__title {
      font-size: 18px;
    }

    .fgrid-card__desc {
      font-size: 12px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.fgrid-card__video video').forEach(function (v) {
      v.setAttribute('playsinline', '');
      v.removeAttribute('controls');
      v.muted = true;
      v.play().catch(function () {});
    });
  });
</script>

{% schema %}
{
  "name": "Feature Grid",
  "tag": "section",
  "class": "feature-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Mastering the Elements"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "NuraCom revolutionises the art of laundry with state-of-the-art laundry solutions"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#0f1529"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Subtext Color",
      "default": "#cccccc"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card Corner Radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "feature_card",
      "name": "Feature Card",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "media_type",
          "label": "Media Type",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video" }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "info": "Supports bold, bullets, line breaks. Press Enter for a new line.",
          "default": "<p>Add your feature description here.</p>"
        },
        {
          "type": "color",
          "id": "card_bg_color",
          "label": "Card Background",
          "default": "#1a2038"
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Title Color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "desc_color",
          "label": "Description Color",
          "default": "#cccccc"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Grid",
      "blocks": [
        { "type": "feature_card" },
        { "type": "feature_card" },
        { "type": "feature_card" },
        { "type": "feature_card" }
      ]
    }
  ]
}
{% endschema %}
