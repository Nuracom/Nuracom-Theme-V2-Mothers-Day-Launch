{% comment %}
  Nuracom Landing — Simple Button
  Drop-in CTA button. Paste a link, pick alignment + style, done.
  Install to: sections/landing-button.liquid
{% endcomment %}

<style>
  #lp-btn-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
    text-align: {{ section.settings.alignment }};
  }

  #lp-btn-{{ section.id }} .lp-btn__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  #lp-btn-{{ section.id }} .lp-btn__caption {
    font-size: 13px;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    font-weight: 700;
    color: {{ section.settings.accent_color }};
    margin: 0 0 14px;
  }

  #lp-btn-{{ section.id }} .lp-btn {
    display: inline-block;
    font-family: inherit;
    font-size: {% if section.settings.size == 'large' %}17px{% elsif section.settings.size == 'small' %}14px{% else %}15.5px{% endif %};
    font-weight: 600;
    letter-spacing: 0.2px;
    line-height: 1;
    padding: {% if section.settings.size == 'large' %}20px 40px{% elsif section.settings.size == 'small' %}12px 24px{% else %}16px 32px{% endif %};
    border-radius: 999px;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s ease, filter 0.2s ease, background 0.2s ease, color 0.2s ease;
    border: 2px solid {{ section.settings.btn_color }};
    {% if section.settings.style == 'outline' %}
      background: transparent;
      color: {{ section.settings.btn_color }};
    {% else %}
      background: {{ section.settings.btn_color }};
      color: {{ section.settings.btn_text_color }};
    {% endif %}
  }

  #lp-btn-{{ section.id }} .lp-btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.08);
    {% if section.settings.style == 'outline' %}
      background: {{ section.settings.btn_color }};
      color: {{ section.settings.btn_text_color }};
    {% endif %}
  }

  #lp-btn-{{ section.id }} .lp-btn svg {
    vertical-align: middle;
    margin-left: 8px;
    transition: transform 0.2s ease;
  }

  #lp-btn-{{ section.id }} .lp-btn:hover svg {
    transform: translateX(3px);
  }

  #lp-btn-{{ section.id }} .lp-btn__sub {
    display: block;
    margin-top: 14px;
    font-size: 13px;
    color: {{ section.settings.sub_color }};
    opacity: 0.75;
  }

  @media (max-width: 560px) {
    #lp-btn-{{ section.id }} {
      padding-left: 18px;
      padding-right: 18px;
    }
    #lp-btn-{{ section.id }} .lp-btn {
      {% if section.settings.full_width_mobile %}
        display: block;
        width: 100%;
      {% endif %}
    }
  }
</style>

<section id="lp-btn-{{ section.id }}">
  <div class="lp-btn__inner">
    {% if section.settings.caption != blank %}
      <p class="lp-btn__caption">{{ section.settings.caption }}</p>
    {% endif %}

    <a class="lp-btn"
       href="{{ section.settings.link | default: '#' }}"
       {% if section.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}>
      {{ section.settings.label }}
      {% if section.settings.show_arrow %}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      {% endif %}
    </a>

    {% if section.settings.sub_text != blank %}
      <span class="lp-btn__sub">{{ section.settings.sub_text }}</span>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Landing — Button",
  "tag": "section",
  "class": "landing-button-section",
  "settings": [
    { "type": "header", "content": "Button" },
    { "type": "text", "id": "label", "label": "Button text", "default": "Shop Nuracom" },
    { "type": "url", "id": "link", "label": "Button link" },
    { "type": "checkbox", "id": "open_new_tab", "label": "Open in new tab", "default": false },
    { "type": "checkbox", "id": "show_arrow", "label": "Show arrow icon", "default": true },
    { "type": "header", "content": "Layout" },
    {
      "type": "select", "id": "alignment", "label": "Alignment", "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Centre" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select", "id": "size", "label": "Size", "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "select", "id": "style", "label": "Style", "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "outline", "label": "Outline" }
      ]
    },
    { "type": "checkbox", "id": "full_width_mobile", "label": "Full width on mobile", "default": true },
    { "type": "range", "id": "padding_top", "label": "Top padding", "default": 40, "min": 0, "max": 120, "step": 4, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "default": 40, "min": 0, "max": 120, "step": 4, "unit": "px" },
    { "type": "header", "content": "Optional text" },
    { "type": "text", "id": "caption", "label": "Caption above button (optional)" },
    { "type": "text", "id": "sub_text", "label": "Sub-text below button (optional)", "default": "Free AU shipping. 2-year warranty." },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "btn_color", "label": "Button colour", "default": "#866653" },
    { "type": "color", "id": "btn_text_color", "label": "Button text colour", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Caption accent", "default": "#866653" },
    { "type": "color", "id": "sub_color", "label": "Sub-text colour", "default": "#101a32" }
  ],
  "presets": [
    { "name": "Landing — Button" }
  ]
}
{% endschema %}
