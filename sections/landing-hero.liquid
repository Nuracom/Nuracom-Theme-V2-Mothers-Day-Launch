{% comment %}
  Nuracom Landing Hero — Above-the-fold, ad-optimised.
  Left-aligned copy, real product image on the right, dual CTAs, trust strip.
  Install to: sections/landing-hero.liquid
{% endcomment %}

<style>
  #lp-hero-{{ section.id }} {
    position: relative;
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 80px 24px 60px;
    overflow: hidden;
  }

  #lp-hero-{{ section.id }} .lp-hero__inner {
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    grid-template-areas:
      "top   media"
      "bottom media";
    column-gap: 60px;
    row-gap: 16px;
    align-items: center;
  }

  #lp-hero-{{ section.id }} .lp-hero__copy-top {
    grid-area: top;
    align-self: end;
  }

  #lp-hero-{{ section.id }} .lp-hero__copy-bottom {
    grid-area: bottom;
    align-self: start;
  }

  #lp-hero-{{ section.id }} .lp-hero__media {
    grid-area: media;
  }

  #lp-hero-{{ section.id }} .lp-hero__eyebrow {
    display: inline-block;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(134,102,83,0.14);
    color: {{ section.settings.accent_color }};
    margin-bottom: 22px;
  }

  #lp-hero-{{ section.id }} .lp-hero__headline {
    font-size: clamp(34px, 5.2vw, 58px);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.6px;
    margin: 0 0 18px;
    color: {{ section.settings.text_color }};
  }

  #lp-hero-{{ section.id }} .lp-hero__headline em {
    font-style: normal;
    color: {{ section.settings.accent_color }};
  }

  #lp-hero-{{ section.id }} .lp-hero__sub {
    font-size: 18px;
    line-height: 1.55;
    max-width: 540px;
    margin: 0 0 34px;
    opacity: 0.85;
  }

  #lp-hero-{{ section.id }} .lp-hero__ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  #lp-hero-{{ section.id }} .lp-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 34px;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.3px;
    text-decoration: none;
    border-radius: 8px;
    transition: transform 0.12s ease, opacity 0.2s ease, background 0.2s ease;
    white-space: nowrap;
  }

  #lp-hero-{{ section.id }} .lp-hero__btn--primary {
    background: {{ section.settings.primary_btn_bg }};
    color: {{ section.settings.primary_btn_text_color }};
  }

  #lp-hero-{{ section.id }} .lp-hero__btn--primary:hover {
    transform: translateY(-1px);
    opacity: 0.94;
  }

  #lp-hero-{{ section.id }} .lp-hero__btn--secondary {
    background: transparent;
    color: {{ section.settings.text_color }};
    border: 1.5px solid {{ section.settings.text_color }};
  }

  #lp-hero-{{ section.id }} .lp-hero__btn--secondary:hover {
    background: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
  }

  #lp-hero-{{ section.id }} .lp-hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 22px;
    font-size: 13.5px;
    opacity: 0.85;
  }

  #lp-hero-{{ section.id }} .lp-hero__trust span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  #lp-hero-{{ section.id }} .lp-hero__trust svg {
    flex-shrink: 0;
    color: {{ section.settings.accent_color }};
  }

  #lp-hero-{{ section.id }} .lp-hero__media {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0,0,0,0.25);
  }

  #lp-hero-{{ section.id }} .lp-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #lp-hero-{{ section.id }} .lp-hero__media-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #242f4d 0%, #3d4c75 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.5);
    font-size: 14px;
  }

  #lp-hero-{{ section.id }} .lp-hero__tag {
    position: absolute;
    bottom: 18px;
    left: 18px;
    background: rgba(255,255,255,0.95);
    color: #1a1a2e;
    padding: 10px 16px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    backdrop-filter: blur(6px);
  }

  @media (max-width: 960px) {
    #lp-hero-{{ section.id }} {
      padding: 48px 20px 44px;
    }
    #lp-hero-{{ section.id }} .lp-hero__inner {
      grid-template-columns: 1fr;
      grid-template-areas:
        "top"
        "media"
        "bottom";
      column-gap: 0;
      row-gap: 28px;
    }
    #lp-hero-{{ section.id }} .lp-hero__copy-top,
    #lp-hero-{{ section.id }} .lp-hero__copy-bottom {
      align-self: stretch;
    }
    #lp-hero-{{ section.id }} .lp-hero__media {
      aspect-ratio: 4 / 3;
    }
    #lp-hero-{{ section.id }} .lp-hero__headline {
      font-size: clamp(28px, 7vw, 40px);
    }
    #lp-hero-{{ section.id }} .lp-hero__sub {
      font-size: 16px;
      margin-bottom: 24px;
    }
    #lp-hero-{{ section.id }} .lp-hero__ctas {
      gap: 10px;
    }
    #lp-hero-{{ section.id }} .lp-hero__btn {
      flex: 1 1 140px;
      padding: 13px 16px;
      font-size: 14px;
      letter-spacing: 0.2px;
    }
    #lp-hero-{{ section.id }} .lp-hero__trust {
      font-size: 12.5px;
      gap: 8px 16px;
    }
  }

  @media (max-width: 420px) {
    #lp-hero-{{ section.id }} .lp-hero__ctas {
      flex-direction: column;
    }
    #lp-hero-{{ section.id }} .lp-hero__btn {
      width: 100%;
      flex: none;
      padding: 14px 20px;
      font-size: 15px;
    }
  }
</style>

<section id="lp-hero-{{ section.id }}">
  <div class="lp-hero__inner">
    <div class="lp-hero__copy-top">
      {% if section.settings.eyebrow != blank %}
        <span class="lp-hero__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}

      <h1 class="lp-hero__headline">{{ section.settings.headline }}</h1>

      {% if section.settings.subheadline != blank %}
        <p class="lp-hero__sub">{{ section.settings.subheadline }}</p>
      {% endif %}
    </div>

    <div class="lp-hero__media">
      {% if section.settings.hero_image != blank %}
        <img src="{{ section.settings.hero_image | image_url: width: 1200 }}"
             alt="{{ section.settings.headline | escape }}"
             loading="eager" fetchpriority="high">
      {% else %}
        <div class="lp-hero__media-placeholder">Product lifestyle image</div>
      {% endif %}

      {% if section.settings.image_tag != blank %}
        <div class="lp-hero__tag">{{ section.settings.image_tag }}</div>
      {% endif %}
    </div>

    <div class="lp-hero__copy-bottom">
      <div class="lp-hero__ctas">
        {% if section.settings.primary_btn_text != blank %}
          <a href="{{ section.settings.primary_btn_url }}" class="lp-hero__btn lp-hero__btn--primary">
            {{ section.settings.primary_btn_text }}
          </a>
        {% endif %}
        {% if section.settings.secondary_btn_text != blank %}
          <a href="{{ section.settings.secondary_btn_url }}" class="lp-hero__btn lp-hero__btn--secondary">
            {{ section.settings.secondary_btn_text }}
          </a>
        {% endif %}
      </div>

      <div class="lp-hero__trust">
        {% for i in (1..4) %}
          {% assign key = 'trust_' | append: i %}
          {% assign val = section.settings[key] %}
          {% if val != blank %}
            <span>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M13.3 4.3 6 11.6 2.7 8.3" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {{ val }}
            </span>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Landing — Hero",
  "tag": "section",
  "class": "landing-hero-section",
  "settings": [
    { "type": "header", "content": "Copy" },
    {
      "type": "text", "id": "eyebrow", "label": "Eyebrow label",
      "default": "Australian-designed smart laundry"
    },
    {
      "type": "text", "id": "headline", "label": "Headline",
      "default": "Dry Clothes Faster Indoors — Without Relying on the Weather"
    },
    {
      "type": "textarea", "id": "subheadline", "label": "Subheadline",
      "default": "Premium ceiling-mounted laundry racks with smart controls, heated drying, lighting, and space-saving convenience for modern Australian homes."
    },
    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "primary_btn_text", "label": "Primary button text", "default": "Compare Models" },
    { "type": "url", "id": "primary_btn_url", "label": "Primary button URL" },
    { "type": "text", "id": "secondary_btn_text", "label": "Secondary button text", "default": "Shop Now" },
    { "type": "url", "id": "secondary_btn_url", "label": "Secondary button URL" },
    { "type": "header", "content": "Trust strip (under buttons)" },
    { "type": "text", "id": "trust_1", "label": "Trust item 1", "default": "Under $1 per drying cycle" },
    { "type": "text", "id": "trust_2", "label": "Trust item 2", "default": "Ships free Australia-wide" },
    { "type": "text", "id": "trust_3", "label": "Trust item 3", "default": "Ceiling-mounted, zero floor space" },
    { "type": "text", "id": "trust_4", "label": "Trust item 4", "default": "2-year Australian warranty" },
    { "type": "header", "content": "Image" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image (real home/laundry setting)" },
    { "type": "text", "id": "image_tag", "label": "Image badge (optional)", "default": "Pictured: Nuracom Aero in modern laundry" },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#101a32" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#C69A7B" },
    { "type": "color", "id": "primary_btn_bg", "label": "Primary button bg", "default": "#866653" },
    { "type": "color", "id": "primary_btn_text_color", "label": "Primary button text colour", "default": "#ffffff" }
  ],
  "presets": [{ "name": "Landing — Hero" }]
}
{% endschema %}
