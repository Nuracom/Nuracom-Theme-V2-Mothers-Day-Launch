{% comment %}
  Product Comparison Section
  - Add to your theme: sections/product-comparison.liquid
  - Then add it via the Theme Customizer or include in a template
{% endcomment %}

<section class="comparison-section" style="background-color: {{ section.settings.bg_color }};">
  <div class="comparison-container">
    {% if section.settings.heading != blank %}
      <h2 class="comparison-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="comparison-grid">
      {% for block in section.blocks %}
        {% if block.type == 'product_card' %}
          <div class="comparison-card" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <div class="comparison-card__image">
                {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', alt: block.settings.title }}
              </div>
            {%- else -%}
              <div class="comparison-card__image comparison-card__image--placeholder">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {%- endif -%}

            <div class="comparison-card__content">
              {% if block.settings.title != blank %}
                <h3 class="comparison-card__title">{{ block.settings.title }}</h3>
              {% endif %}

              {% if block.settings.subtitle_top != blank %}
                <p class="comparison-card__subtitle-top">{{ block.settings.subtitle_top }}</p>
              {% endif %}

              {% if block.settings.color_swatches != blank %}
                <div class="comparison-card__swatches">
                  <span class="comparison-card__swatches-label">Available Colours:</span>
                  <div class="comparison-card__swatch-dots">
                    {% assign colors = block.settings.color_swatches | split: ',' %}
                    {% for color in colors %}
                      <span class="comparison-card__swatch" style="background-color: {{ color | strip }};"></span>
                    {% endfor %}
                  </div>
                </div>
              {% endif %}

              <ul class="comparison-card__features">
                {% for i in (1..15) %}
                  {% assign feature_id = 'feature_' | append: i %}
                  {% assign feature_val = block.settings[feature_id] %}
                  {% if feature_val != blank %}
                    <li class="comparison-card__feature">
                      <svg class="comparison-card__check" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M13.3 4.3L6 11.6L2.7 8.3" stroke="{{ block.settings.highlight_color | default: '#8B7355' }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <span>{{ feature_val }}</span>
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>

              {% if block.settings.button_text != blank %}
                <a href="{{ block.settings.button_url }}" class="comparison-card__button" style="background-color: {{ block.settings.button_color | default: '#8B7355' }};">
                  {{ block.settings.button_text }}
                </a>
              {% endif %}

              {% if block.settings.subtitle_bottom != blank %}
                <p class="comparison-card__subtitle-bottom">{{ block.settings.subtitle_bottom }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.footer_text != blank %}
      <div class="comparison-footer">
        <a href="{{ section.settings.footer_url }}" class="comparison-footer__link">
          {{ section.settings.footer_text }} &rsaquo;
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .comparison-section {
    padding: 60px 20px;
  }

  .comparison-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .comparison-heading {
    text-align: center;
    font-size: 32px;
    font-weight: 600;
    margin-bottom: 40px;
    color: #1a1a1a;
  }

  .comparison-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: start;
  }

  .comparison-card {
    background: #ffffff;
    border: 1px solid #e8e3dd;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .comparison-card__image {
    padding: 30px 30px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 160px;
  }

  .comparison-card__image img {
    max-width: 100%;
    height: auto;
    max-height: 140px;
    object-fit: contain;
  }

  .comparison-card__image--placeholder svg {
    max-width: 200px;
    height: auto;
  }

  .comparison-card__content {
    padding: 0 30px 30px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .comparison-card__title {
    font-size: 22px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 4px;
  }

  .comparison-card__subtitle-top {
    font-size: 13px;
    color: #888;
    margin: 0 0 16px;
  }

  .comparison-card__swatches {
    margin-bottom: 20px;
  }

  .comparison-card__swatches-label {
    font-size: 12px;
    color: #999;
    display: block;
    margin-bottom: 6px;
  }

  .comparison-card__swatch-dots {
    display: flex;
    gap: 6px;
  }

  .comparison-card__swatch {
    width: 22px;
    height: 22px;
    border-radius: 4px;
    border: 1px solid #ddd;
    display: inline-block;
  }

  .comparison-card__features {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    flex: 1;
  }

  .comparison-card__feature {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 7px 0;
    font-size: 14px;
    color: #333;
    border-bottom: 1px solid #f2efe9;
  }

  .comparison-card__feature:last-child {
    border-bottom: none;
  }

  .comparison-card__check {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .comparison-card__button {
    display: block;
    width: 100%;
    text-align: center;
    padding: 14px 20px;
    border-radius: 8px;
    color: #ffffff;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    font-style: italic;
    transition: opacity 0.2s ease;
  }

  .comparison-card__button:hover {
    opacity: 0.9;
    color: #ffffff;
  }

  .comparison-card__subtitle-bottom {
    font-size: 12px;
    font-style: italic;
    color: #888;
    text-align: center;
    margin: 12px 0 0;
  }

  .comparison-footer {
    text-align: center;
    margin-top: 32px;
  }

  .comparison-footer__link {
    font-size: 14px;
    color: #1a1a1a;
    text-decoration: underline;
    font-weight: 500;
  }

  .comparison-footer__link:hover {
    color: #8B7355;
  }

  @media (max-width: 900px) {
    .comparison-grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin: 0 auto;
    }
  }

  @media (max-width: 600px) {
    .comparison-section {
      padding: 40px 16px;
    }

    .comparison-card__content {
      padding: 0 20px 24px;
    }

    .comparison-card__image {
      padding: 20px 20px 16px;
    }

    .comparison-heading {
      font-size: 24px;
    }
  }
</style>

