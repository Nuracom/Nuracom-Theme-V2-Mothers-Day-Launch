{% comment %}
  Why Nuracom Section
  - Hero banner with heading + subtext
  - Alternating text/image rows using blocks
  - Fully configurable via customizer
  Add to: sections/why-nuracom.liquid
{% endcomment %}

<section id="wn-{{ section.id }}">

  <!-- Hero Banner -->
  {% if section.settings.hero_heading != blank %}
    <div class="wn-hero">
      {% if section.settings.hero_image != blank %}
        {{ section.settings.hero_image | image_url: width: 1920 | image_tag: class: 'wn-hero__bg', alt: section.settings.hero_heading, loading: 'lazy' }}
      {% endif %}
      <div class="wn-hero__overlay"></div>
      <div class="wn-hero__content">
        <h1 class="wn-hero__heading">{{ section.settings.hero_heading }}</h1>
        {% if section.settings.hero_subtext != blank %}
          <p class="wn-hero__subtext">{{ section.settings.hero_subtext }}</p>
        {% endif %}
      </div>
    </div>
  {% endif %}

  <!-- Alternating Rows -->
  <div class="wn-rows">
    {% for block in section.blocks %}
      {% if block.type == 'feature_row' %}
        {% comment %} Alternate: even blocks = image right, odd blocks = image left {% endcomment %}
        {% assign row_mod = forloop.index0 | modulo: 2 %}
        <div class="wn-row{% if row_mod == 0 %} wn-row--img-right{% else %} wn-row--img-left{% endif %}" style="background-color: {{ block.settings.row_bg_color }};" {{ block.shopify_attributes }}>
          <div class="wn-row__inner">
            <div class="wn-row__text">
              {% if block.settings.heading != blank %}
                <h2 class="wn-row__heading">{{ block.settings.heading }}</h2>
              {% endif %}
              {% if block.settings.body != blank %}
                <div class="wn-row__body">{{ block.settings.body }}</div>
              {% endif %}
              {% if block.settings.btn_text != blank and block.settings.btn_url != blank %}
                <a href="{{ block.settings.btn_url }}" class="wn-row__btn">{{ block.settings.btn_text }}</a>
              {% endif %}
            </div>
            <div class="wn-row__media">
              {% if block.settings.video != blank %}
                {% comment %} Shopify-hosted video {% endcomment %}
                <div class="wn-row__video-wrap">
                  {{ block.settings.video | video_tag: autoplay: block.settings.video_autoplay, loop: block.settings.video_loop, muted: block.settings.video_muted, controls: block.settings.video_controls, class: 'wn-row__video', image_size: '800x' }}
                </div>
              {% elsif block.settings.video_url != blank %}
                {% comment %} External video (YouTube / Vimeo) {% endcomment %}
                <div class="wn-row__video-wrap">
                  {% if block.settings.video_url.type == 'youtube' %}
                    <iframe
                      src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?rel=0{% if block.settings.video_autoplay %}&autoplay=1&mute=1{% endif %}{% if block.settings.video_loop %}&loop=1&playlist={{ block.settings.video_url.id }}{% endif %}"
                      class="wn-row__iframe"
                      allow="autoplay; encrypted-media"
                      allowfullscreen
                      loading="lazy"
                      title="{{ block.settings.heading | escape }}"
                    ></iframe>
                  {% elsif block.settings.video_url.type == 'vimeo' %}
                    <iframe
                      src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}?{% if block.settings.video_autoplay %}autoplay=1&muted=1{% endif %}{% if block.settings.video_loop %}&loop=1{% endif %}"
                      class="wn-row__iframe"
                      allow="autoplay; encrypted-media"
                      allowfullscreen
                      loading="lazy"
                      title="{{ block.settings.heading | escape }}"
                    ></iframe>
                  {% endif %}
                </div>
              {% elsif block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 800 | image_tag: alt: block.settings.heading, loading: 'lazy', class: 'wn-row__img' }}
              {% else %}
                <div class="wn-row__placeholder"></div>
              {% endif %}
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

</section>

<style>
  #wn-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
  }

  /* ── Hero Banner ── */
  #wn-{{ section.id }} .wn-hero {
    position: relative;
    width: 100%;
    min-height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  #wn-{{ section.id }} .wn-hero__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #wn-{{ section.id }} .wn-hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ section.settings.hero_overlay_color }};
    opacity: {{ section.settings.hero_overlay_opacity | divided_by: 100.0 }};
  }

  #wn-{{ section.id }} .wn-hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 60px 20px;
    max-width: 700px;
  }

  #wn-{{ section.id }} .wn-hero__heading {
    font-size: 42px;
    font-weight: 700;
    color: {{ section.settings.hero_text_color }};
    margin: 0 0 12px;
    line-height: 1.2;
  }

  #wn-{{ section.id }} .wn-hero__subtext {
    font-size: 16px;
    line-height: 1.6;
    color: {{ section.settings.hero_text_color }};
    margin: 0;
    opacity: 0.9;
  }

  /* ── Alternating Rows ── */
  #wn-{{ section.id }} .wn-row__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    padding: 60px 20px;
  }

  /* Image right: text first */
  #wn-{{ section.id }} .wn-row--img-right .wn-row__text {
    order: 1;
  }
  #wn-{{ section.id }} .wn-row--img-right .wn-row__media {
    order: 2;
  }

  /* Image left: image first */
  #wn-{{ section.id }} .wn-row--img-left .wn-row__text {
    order: 2;
  }
  #wn-{{ section.id }} .wn-row--img-left .wn-row__media {
    order: 1;
  }

  #wn-{{ section.id }} .wn-row__heading {
    font-size: 28px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 16px;
    line-height: 1.25;
  }

  #wn-{{ section.id }} .wn-row__body {
    font-size: 15px;
    line-height: 1.75;
    color: {{ section.settings.body_color }};
  }

  #wn-{{ section.id }} .wn-row__body p {
    margin: 0 0 12px;
  }

  #wn-{{ section.id }} .wn-row__body p:last-child {
    margin-bottom: 0;
  }

  #wn-{{ section.id }} .wn-row__btn {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 28px;
    background: {{ section.settings.btn_bg_color }};
    color: {{ section.settings.btn_text_color }};
    border-radius: 6px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    transition: opacity 0.2s ease;
  }

  #wn-{{ section.id }} .wn-row__btn:hover {
    opacity: 0.9;
  }

  #wn-{{ section.id }} .wn-row__img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
    object-fit: cover;
  }

  /* ── Video ── */
  #wn-{{ section.id }} .wn-row__video-wrap {
    position: relative;
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: #000;
  }

  #wn-{{ section.id }} .wn-row__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 8px;
  }

  #wn-{{ section.id }} .wn-row__iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  #wn-{{ section.id }} .wn-row__placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #f0f0f0;
    border-radius: 8px;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    #wn-{{ section.id }} .wn-hero {
      min-height: 220px;
    }

    #wn-{{ section.id }} .wn-hero__heading {
      font-size: 30px;
    }

    #wn-{{ section.id }} .wn-row__inner {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 40px 20px;
    }

    /* On mobile, always text first, image second */
    #wn-{{ section.id }} .wn-row--img-left .wn-row__text,
    #wn-{{ section.id }} .wn-row--img-right .wn-row__text {
      order: 1;
    }
    #wn-{{ section.id }} .wn-row--img-left .wn-row__media,
    #wn-{{ section.id }} .wn-row--img-right .wn-row__media {
      order: 2;
    }

    #wn-{{ section.id }} .wn-row__heading {
      font-size: 24px;
    }
  }
</style>

{% schema %}
{
  "name": "Why Nuracom",
  "tag": "section",
  "class": "why-nuracom-section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Hero Banner"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero Heading",
      "default": "Why Nuracom?"
    },
    {
      "type": "text",
      "id": "hero_subtext",
      "label": "Hero Subtext",
      "default": "Smarter drying. Better hygiene. Designed for modern homes."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    },
    {
      "type": "color",
      "id": "hero_text_color",
      "label": "Hero Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "hero_overlay_color",
      "label": "Hero Overlay Color",
      "default": "#101a32"
    },
    {
      "type": "range",
      "id": "hero_overlay_opacity",
      "label": "Hero Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 55,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Row Styling"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Row Heading Color",
      "default": "#101a32"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Row Body Text Color",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button Background",
      "default": "#101a32"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "feature_row",
      "name": "Feature Row",
      "limit": 10,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Feature Heading"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body Text",
          "default": "<p>Describe this feature and why it matters to your customers.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Used as fallback if no video is set"
        },
        {
          "type": "header",
          "content": "Video (optional — overrides image)"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Shopify-Hosted Video",
          "info": "Upload a video via Settings → Files, then select it here"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "External Video URL",
          "accept": ["youtube", "vimeo"],
          "info": "Paste a YouTube or Vimeo link. Used only if no hosted video is set."
        },
        {
          "type": "checkbox",
          "id": "video_autoplay",
          "label": "Autoplay",
          "default": true,
          "info": "Autoplayed videos are always muted by browsers"
        },
        {
          "type": "checkbox",
          "id": "video_loop",
          "label": "Loop",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "video_muted",
          "label": "Muted",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "video_controls",
          "label": "Show Controls",
          "default": false
        },
        {
          "type": "color",
          "id": "row_bg_color",
          "label": "Row Background Color",
          "default": "#ffffff",
          "info": "Alternate between white and a light colour for visual contrast"
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Text (optional)",
          "info": "Leave blank to hide button"
        },
        {
          "type": "url",
          "id": "btn_url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Nuracom",
      "blocks": [
        {
          "type": "feature_row",
          "settings": {
            "heading": "Industry-Leading Drying Technology",
            "body": "<p>Our turbo fan system dries clothes up to 3x faster than traditional racks. With multiple fan speeds and hot air circulation, your laundry is ready in hours — not days.</p>",
            "row_bg_color": "#ffffff"
          }
        },
        {
          "type": "feature_row",
          "settings": {
            "heading": "UV Sanitation & Dust Mite Removal",
            "body": "<p>Built-in UV sterilisation lamps eliminate up to 99.9% of bacteria and dust mites from your clothes. Clean laundry isn't just dry — it's hygienically safe for your family.</p>",
            "row_bg_color": "#f8f5f1"
          }
        },
        {
          "type": "feature_row",
          "settings": {
            "heading": "Smart Home Integration",
            "body": "<p>Control your NuraCom rack with voice commands or the included remote. Compatible with smart home setups, so you can lower, raise, and dry your laundry without lifting a finger.</p>",
            "row_bg_color": "#ffffff"
          }
        },
        {
          "type": "feature_row",
          "settings": {
            "heading": "Premium Build Quality",
            "body": "<p>Crafted from top-grade aluminium alloy with a 30kg load capacity. Every NuraCom rack is built to last with a 5-year warranty and free delivery included.</p>",
            "row_bg_color": "#f8f5f1"
          }
        }
      ]
    }
  ]
}
{% endschema %}
