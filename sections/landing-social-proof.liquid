        { "type": "textarea", "id": "desc", "label": "Description", "default": "Full replacement coverage on motors and electronics." },
        { "type": "header", "content": "Fine-print link (optional)" },
        { "type": "text", "id": "link_text", "label": "Link text", "default": "T&Cs apply", "info": "e.g. \"T&Cs apply\" or \"See policy\"" },
        { "type": "url", "id": "link_url", "label": "Link URL (warranty / returns page)" }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "Landing — Social Proof",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "Honestly the best upgrade we've done to our laundry. Out of the way, lights up the whole room, and dries faster than our dryer in winter.",
            "name": "Sarah M.",
            "location": "Brisbane, QLD",
            "show_stars": true
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "I live in a Sydney apartment with no balcony airflow. Nuracom solved the problem completely — and the remote control genuinely feels premium.",
            "name": "David L.",
            "location": "Sydney, NSW",
            "show_stars": true
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Installation was quick — sparky had it up in about 45 minutes. Four school uniforms dry overnight without touching the dryer.",
            "name": "Emma & Ryan T.",
            "location": "Melbourne, VIC",
            "show_stars": true
          }
        },
        { "type": "photo", "settings": { "alt": "Nuracom in modern laundry" } },
        { "type": "photo", "settings": { "alt": "Ceiling-mounted install" } },
        { "type": "photo", "settings": { "alt": "Close-up detail" } },
        { "type": "photo", "settings": { "alt": "Clothes drying indoors" } },
        {
          "type": "trust",
          "settings": {
