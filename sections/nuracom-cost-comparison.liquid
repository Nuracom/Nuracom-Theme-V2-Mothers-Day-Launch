{% comment %}
  Nuracom Cost Comparison — Belief #4 (this pays for itself)
  Real numbers, side-by-side. The single highest-converting section on the page.
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    --brand-deep: {{ section.settings.brand_deep }};
    --brand-accent: {{ section.settings.brand_accent }};
    --navy: {{ section.settings.navy }};
    --cream: {{ section.settings.cream }};
    --text-primary: {{ section.settings.text_primary }};
    --text-secondary: {{ section.settings.text_secondary }};
    --text-muted: {{ section.settings.text_muted }};
    --white: {{ section.settings.white }};
    --positive: {{ section.settings.positive_color }};
    --negative: {{ section.settings.negative_color }};
    --radius: 12px;
    --radius-lg: 20px;
    --max-width: 1120px;
    --section-pad: clamp(44px, 6vw, 80px);
  }
  #shopify-section-{{ section.id }} * { box-sizing: border-box; }
  #shopify-section-{{ section.id }} .ncost { padding: var(--section-pad) 0; background: {{ section.settings.bg_color }}; font-family: 'Inter', -apple-system, sans-serif; }
  #shopify-section-{{ section.id }} .ncost__container { max-width: var(--max-width); margin: 0 auto; padding: 0 24px; }
  #shopify-section-{{ section.id }} .ncost__header { text-align: center; max-width: 750px; margin: 0 auto 50px; }
  #shopify-section-{{ section.id }} .ncost__kicker { font-size: 0.75rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--brand-accent); margin-bottom: 12px; display: block; }
  #shopify-section-{{ section.id }} .ncost__headline { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.2; color: var(--navy); margin: 0 0 20px; }
  #shopify-section-{{ section.id }} .ncost__sub { font-size: clamp(1.05rem, 1.5vw, 1.2rem); color: var(--text-secondary); line-height: 1.7; margin: 0 auto; max-width: 660px; }
  #shopify-section-{{ section.id }} .ncost__sub strong { color: var(--text-primary); font-weight: 600; }
  #shopify-section-{{ section.id }} .ncost__comparison { display: grid; grid-template-columns: 1fr auto 1fr; gap: 32px; align-items: stretch; max-width: 960px; margin: 0 auto 40px; }
  #shopify-section-{{ section.id }} .ncost__card { background: var(--cream); border-radius: var(--radius-lg); padding: 36px 28px; text-align: center; display: flex; flex-direction: column; }
  #shopify-section-{{ section.id }} .ncost__card--nuracom { background: var(--navy); color: var(--white); }
  #shopify-section-{{ section.id }} .ncost__card-label { font-size: 0.75rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 6px; opacity: 0.6; }
  #shopify-section-{{ section.id }} .ncost__card-method { font-size: 1.3rem; font-weight: 700; margin: 0 0 16px; }
  #shopify-section-{{ section.id }} .ncost__card-price { font-family: 'Playfair Display', Georgia, serif; font-size: 3.2rem; font-weight: 700; line-height: 1; margin: 0 0 4px; }
  #shopify-section-{{ section.id }} .ncost__card--dryer .ncost__card-price { color: var(--negative); }
  #shopify-section-{{ section.id }} .ncost__card--nuracom .ncost__card-price { color: var(--positive); }
  #shopify-section-{{ section.id }} .ncost__card-per { font-size: 0.85rem; opacity: 0.6; margin: 0 0 20px; }
  #shopify-section-{{ section.id }} .ncost__card-breakdown { text-align: left; font-size: 0.85rem; line-height: 1.8; padding: 16px 0; border-top: 1px solid rgba(0,0,0,0.08); }
  #shopify-section-{{ section.id }} .ncost__card--nuracom .ncost__card-breakdown { border-top-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.85); }
  #shopify-section-{{ section.id }} .ncost__card-breakdown strong { font-weight: 700; }
  #shopify-section-{{ section.id }} .ncost__card--nuracom .ncost__card-breakdown strong { color: #fff; }
  #shopify-section-{{ section.id }} .ncost__card-row { display: flex; justify-content: space-between; align-items: baseline; padding: 2px 0; }
  #shopify-section-{{ section.id }} .ncost__card-row--total { border-top: 1px solid rgba(0,0,0,0.1); margin-top: 8px; padding-top: 10px; font-weight: 700; font-size: 0.95rem; }
  #shopify-section-{{ section.id }} .ncost__card--nuracom .ncost__card-row--total { border-top-color: rgba(255,255,255,0.2); }
  #shopify-section-{{ section.id }} .ncost__card--dryer .ncost__card-row--total strong { color: var(--negative); }
  #shopify-section-{{ section.id }} .ncost__card--nuracom .ncost__card-row--total strong { color: var(--positive); }
  #shopify-section-{{ section.id }} .ncost__card-capacity { background: rgba(0,0,0,0.04); border-radius: 8px; padding: 12px 14px; margin-top: 16px; font-size: 0.85rem; line-height: 1.5; text-align: center; }
  #shopify-section-{{ section.id }} .ncost__card--nuracom .ncost__card-capacity { background: rgba(255,255,255,0.08); }
  #shopify-section-{{ section.id }} .ncost__card-annual { font-size: 0.95rem; padding: 14px 0 0; border-top: 1px solid rgba(0,0,0,0.08); margin-top: auto; }
  #shopify-section-{{ section.id }} .ncost__card--nuracom .ncost__card-annual { border-top-color: rgba(255,255,255,0.15); }
  #shopify-section-{{ section.id }} .ncost__card-annual strong { display: block; font-size: 1.3rem; margin-top: 4px; }
  #shopify-section-{{ section.id }} .ncost__card--dryer .ncost__card-annual strong { color: var(--negative); }
  #shopify-section-{{ section.id }} .ncost__card--nuracom .ncost__card-annual strong { color: var(--positive); }
  #shopify-section-{{ section.id }} .ncost__vs { font-family: 'Playfair Display', Georgia, serif; font-size: 1.5rem; font-weight: 700; color: var(--text-muted); display: flex; align-items: center; justify-content: center; }
  #shopify-section-{{ section.id }} .ncost__capacity-note { text-align: center; max-width: 800px; margin: 0 auto 40px; background: {{ section.settings.capacity_note_bg }}; border-radius: var(--radius); padding: 20px 28px; }
  #shopify-section-{{ section.id }} .ncost__capacity-headline { font-size: 1.1rem; font-weight: 700; color: {{ section.settings.capacity_note_color }}; margin: 0 0 4px; }
  #shopify-section-{{ section.id }} .ncost__capacity-text { font-size: 0.9rem; color: {{ section.settings.capacity_note_color }}; opacity: 0.85; line-height: 1.6; margin: 0; }
  #shopify-section-{{ section.id }} .ncost__capacity-text strong { font-weight: 700; }
  #shopify-section-{{ section.id }} .ncost__savings { text-align: center; max-width: 700px; margin: 0 auto; }
  #shopify-section-{{ section.id }} .ncost__savings-box { background: {{ section.settings.savings_bg }}; border-radius: var(--radius); padding: 28px 32px; margin-bottom: 16px; }
  #shopify-section-{{ section.id }} .ncost__savings-headline { font-size: 1.6rem; font-weight: 800; color: {{ section.settings.savings_color }}; margin: 0 0 6px; }
  #shopify-section-{{ section.id }} .ncost__savings-sub { font-size: 0.95rem; color: {{ section.settings.savings_color }}; opacity: 0.85; line-height: 1.6; margin: 0; }
  #shopify-section-{{ section.id }} .ncost__savings-note { font-size: 0.8rem; color: var(--text-muted); line-height: 1.5; max-width: 620px; margin: 0 auto; }
  #shopify-section-{{ section.id }} .ncost__reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
  #shopify-section-{{ section.id }} .ncost__reveal.is-visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .ncost__comparison { grid-template-columns: 1fr; max-width: 420px; margin: 0 auto 40px; }
    #shopify-section-{{ section.id }} .ncost__vs { padding: 8px 0; }
  }
</style>

<section class="ncost">
  <div class="ncost__container">
    <div class="ncost__header ncost__reveal">
      {% if section.settings.kicker != blank %}
        <span class="ncost__kicker">{{ section.settings.kicker }}</span>
      {% endif %}
      <h2 class="ncost__headline">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="ncost__sub">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="ncost__comparison ncost__reveal">
      <div class="ncost__card ncost__card--dryer">
        <p class="ncost__card-label">{{ section.settings.dryer_label }}</p>
        <p class="ncost__card-method">{{ section.settings.dryer_method }}</p>
        <p class="ncost__card-price">{{ section.settings.dryer_price }}</p>
        <p class="ncost__card-per">{{ section.settings.dryer_per }}</p>
        <div class="ncost__card-breakdown">
          <div class="ncost__card-row"><span>{{ section.settings.dryer_row_1_label }}</span> <strong>{{ section.settings.dryer_row_1_value }}</strong></div>
          <div class="ncost__card-row"><span>{{ section.settings.dryer_row_2_label }}</span> <strong>{{ section.settings.dryer_row_2_value }}</strong></div>
          <div class="ncost__card-row"><span>{{ section.settings.dryer_row_3_label }}</span> <strong>{{ section.settings.dryer_row_3_value }}</strong></div>
          <div class="ncost__card-row ncost__card-row--total"><span>{{ section.settings.dryer_total_label }}</span> <strong>{{ section.settings.dryer_total_value }}</strong></div>
        </div>
        <div class="ncost__card-capacity">{{ section.settings.dryer_capacity_text }}</div>
        <div class="ncost__card-annual">
          {{ section.settings.dryer_annual_label }}
          <strong>{{ section.settings.dryer_annual_value }}</strong>
        </div>
      </div>

      <div class="ncost__vs">vs</div>

      <div class="ncost__card ncost__card--nuracom">
        <p class="ncost__card-label">{{ section.settings.nuracom_label }}</p>
        <p class="ncost__card-method">{{ section.settings.nuracom_method }}</p>
        <p class="ncost__card-price">{{ section.settings.nuracom_price }}</p>
        <p class="ncost__card-per">{{ section.settings.nuracom_per }}</p>
        <div class="ncost__card-breakdown">
          <div class="ncost__card-row"><span>{{ section.settings.nuracom_row_1_label }}</span> <strong>{{ section.settings.nuracom_row_1_value }}</strong></div>
          <div class="ncost__card-row"><span>{{ section.settings.nuracom_row_2_label }}</span> <strong>{{ section.settings.nuracom_row_2_value }}</strong></div>
          <div class="ncost__card-row"><span>{{ section.settings.nuracom_row_3_label }}</span> <strong>{{ section.settings.nuracom_row_3_value }}</strong></div>
          <div class="ncost__card-row ncost__card-row--total"><span>{{ section.settings.nuracom_total_label }}</span> <strong>{{ section.settings.nuracom_total_value }}</strong></div>
        </div>
        <div class="ncost__card-capacity">{{ section.settings.nuracom_capacity_text }}</div>
        <div class="ncost__card-annual">
          {{ section.settings.nuracom_annual_label }}
          <strong>{{ section.settings.nuracom_annual_value }}</strong>
        </div>
      </div>
    </div>

    {% if section.settings.capacity_note_headline != blank %}
      <div class="ncost__capacity-note ncost__reveal">
        <p class="ncost__capacity-headline">{{ section.settings.capacity_note_headline }}</p>
        <p class="ncost__capacity-text">{{ section.settings.capacity_note_text }}</p>
      </div>
    {% endif %}

    <div class="ncost__savings ncost__reveal">
      <div class="ncost__savings-box">
        <p class="ncost__savings-headline">{{ section.settings.savings_headline }}</p>
        <p class="ncost__savings-sub">{{ section.settings.savings_sub }}</p>
      </div>
      {% if section.settings.savings_note != blank %}
        <p class="ncost__savings-note">{{ section.settings.savings_note }}</p>
      {% endif %}
    </div>
  </div>
</section>

<script>
  (function() {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;
    var els = root.querySelectorAll('.ncost__reveal');
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
    els.forEach(function(el) { io.observe(el); });
  })();
</script>

{% schema %}
{
  "name": "Cost Comparison",
  "tag": "section",
  "class": "nuracom-cost-comparison-section",
  "settings": [
    { "type": "header", "content": "Section intro" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "The Maths" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your Tumble Dryer Is Quietly Costing You Hundreds Every Year" },
    { "type": "richtext", "id": "subheading", "label": "Subheading", "default": "<p>We ran the numbers using real product specs and the current Australian average electricity rate of <strong>~36c/kWh</strong>. Here's what most families never calculate.</p>" },

    { "type": "header", "content": "Dryer card" },
    { "type": "text", "id": "dryer_label", "label": "Top label", "default": "Traditional" },
    { "type": "text", "id": "dryer_method", "label": "Method", "default": "Tumble Dryer" },
    { "type": "text", "id": "dryer_price", "label": "Price", "default": "$1.42" },
    { "type": "text", "id": "dryer_per", "label": "Per", "default": "per load" },
    { "type": "text", "id": "dryer_row_1_label", "label": "Row 1 label", "default": "Avg. rated power" },
    { "type": "text", "id": "dryer_row_1_value", "label": "Row 1 value", "default": "~2,200W" },
    { "type": "text", "id": "dryer_row_2_label", "label": "Row 2 label", "default": "Avg. cycle time" },
    { "type": "text", "id": "dryer_row_2_value", "label": "Row 2 value", "default": "~110 min" },
    { "type": "text", "id": "dryer_row_3_label", "label": "Row 3 label", "default": "Energy per load" },
    { "type": "text", "id": "dryer_row_3_value", "label": "Row 3 value", "default": "~4.0 kWh" },
    { "type": "text", "id": "dryer_total_label", "label": "Total row label", "default": "Cost @ 36c/kWh" },
    { "type": "text", "id": "dryer_total_value", "label": "Total row value", "default": "$1.42" },
    { "type": "richtext", "id": "dryer_capacity_text", "label": "Capacity note", "default": "<p><strong>Capacity: ~7&ndash;8 kg per load</strong><br>A family of 4 averages <strong>6 dryer loads/week</strong></p>" },
    { "type": "text", "id": "dryer_annual_label", "label": "Annual label", "default": "Annual cost (6 loads × 52 weeks)" },
    { "type": "text", "id": "dryer_annual_value", "label": "Annual value", "default": "$443/year" },

    { "type": "header", "content": "Nuracom card" },
    { "type": "text", "id": "nuracom_label", "label": "Top label", "default": "Smart" },
    { "type": "text", "id": "nuracom_method", "label": "Method", "default": "Nuracom System" },
    { "type": "text", "id": "nuracom_price", "label": "Price", "default": "$0.57" },
    { "type": "text", "id": "nuracom_per", "label": "Per", "default": "per cycle" },
    { "type": "text", "id": "nuracom_row_1_label", "label": "Row 1 label", "default": "Rated power" },
    { "type": "text", "id": "nuracom_row_1_value", "label": "Row 1 value", "default": "800W" },
    { "type": "text", "id": "nuracom_row_2_label", "label": "Row 2 label", "default": "Cycle (auto shut-off)" },
    { "type": "text", "id": "nuracom_row_2_value", "label": "Row 2 value", "default": "2 hours" },
    { "type": "text", "id": "nuracom_row_3_label", "label": "Row 3 label", "default": "Energy per cycle" },
    { "type": "text", "id": "nuracom_row_3_value", "label": "Row 3 value", "default": "1.6 kWh" },
    { "type": "text", "id": "nuracom_total_label", "label": "Total row label", "default": "Cost @ 36c/kWh" },
    { "type": "text", "id": "nuracom_total_value", "label": "Total row value", "default": "$0.57" },
    { "type": "richtext", "id": "nuracom_capacity_text", "label": "Capacity note", "default": "<p><strong>Capacity: up to 35 kg</strong><br>That's <strong>~5 dryer loads in 2&ndash;3 rack loads</strong></p>" },
    { "type": "text", "id": "nuracom_annual_label", "label": "Annual label", "default": "Annual cost (3 cycles × 52 weeks)" },
    { "type": "text", "id": "nuracom_annual_value", "label": "Annual value", "default": "$89/year" },

    { "type": "header", "content": "Capacity callout" },
    { "type": "text", "id": "capacity_note_headline", "label": "Callout headline", "default": "The capacity difference is the real game-changer" },
    { "type": "richtext", "id": "capacity_note_text", "label": "Callout body", "default": "<p>A standard tumble dryer holds 7&ndash;8 kg per load. A Nuracom holds <strong>up to 35&ndash;45 kg</strong> depending on model — meaning the same weekly laundry that takes <strong>6 dryer cycles</strong> can be handled in just <strong>2&ndash;3 Nuracom cycles</strong>. Fewer cycles = dramatically less energy, even before you factor in the lower wattage.</p>" },

    { "type": "header", "content": "Savings box" },
    { "type": "text", "id": "savings_headline", "label": "Savings headline", "default": "Save $354+ per year on energy alone" },
    { "type": "textarea", "id": "savings_sub", "label": "Savings subtext", "default": "That's $443 in dryer costs vs just $89 with Nuracom. Your system pays for itself — then keeps saving you money every year after." },
    { "type": "textarea", "id": "savings_note", "label": "Source / assumptions note", "default": "Based on the current Australian average electricity rate of ~36c/kWh (source: Canstar, CHOICE). Tumble dryer: standard vented model at ~4 kWh per load (source: CHOICE Australia). Nuracom: 800W rated, 2-hour auto shut-off cycle. Capacity based on the Nuracom Aero (35 kg); Stratos holds up to 45 kg. A family of 4 averaging ~48 kg of laundry per week (~3 Nuracom cycles vs 6 dryer loads) is used for load calculations." },

    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "brand_deep", "label": "Brand deep", "default": "#5E0404" },
    { "type": "color", "id": "brand_accent", "label": "Brand accent (kicker)", "default": "#a8321a" },
    { "type": "color", "id": "navy", "label": "Navy (titles + Nuracom card bg)", "default": "#101a32" },
    { "type": "color", "id": "cream", "label": "Cream (dryer card bg)", "default": "#f8f5f1" },
    { "type": "color", "id": "text_primary", "label": "Text primary", "default": "#1a1a1a" },
    { "type": "color", "id": "text_secondary", "label": "Text secondary", "default": "#555555" },
    { "type": "color", "id": "text_muted", "label": "Text muted", "default": "#888888" },
    { "type": "color", "id": "white", "label": "White", "default": "#ffffff" },
    { "type": "color", "id": "positive_color", "label": "Positive / savings (Nuracom numbers)", "default": "#4ade80" },
    { "type": "color", "id": "negative_color", "label": "Negative / cost (dryer numbers)", "default": "#dc2626" },
    { "type": "color", "id": "capacity_note_bg", "label": "Capacity callout background", "default": "#fef3c7" },
    { "type": "color", "id": "capacity_note_color", "label": "Capacity callout text", "default": "#92400e" },
    { "type": "color", "id": "savings_bg", "label": "Savings box background", "default": "#dcfce7" },
    { "type": "color", "id": "savings_color", "label": "Savings box text", "default": "#166534" }
  ],
  "presets": [ { "name": "Cost Comparison" } ]
}
{% endschema %}
