{% comment %}
  Control Modes Section
  - Centered heading + subtitle
  - 2x2 grid of cards with icon, title, description
  - Soft rounded cards with subtle shadow
  Add to: sections/control-modes.liquid
{% endcomment %}

<section id="cm-{{ section.id }}">
  <div class="cm-inner">

    <div class="cm-header">
      {% if section.settings.heading != blank %}
        <h2 class="cm-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="cm-subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="cm-grid">
      {% for block in section.blocks %}
        <div class="cm-card" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="cm-card__icon">
              <img
                src="{{ block.settings.icon | image_url: width: 80 }}"
                alt="{{ block.settings.title | escape }}"
                width="36"
                height="36"
                loading="lazy"
              >
            </div>
          {% elsif block.settings.icon_emoji != blank %}
            <div class="cm-card__icon cm-card__icon--emoji">
              {{ block.settings.icon_emoji }}
            </div>
          {% endif %}

          {% if block.settings.title != blank %}
            <h3 class="cm-card__title">{{ block.settings.title }}</h3>
          {% endif %}

          {% if block.settings.description != blank %}
            <p class="cm-card__desc">{{ block.settings.description }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
  #cm-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
  }

  #cm-{{ section.id }} .cm-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Header ── */
  #cm-{{ section.id }} .cm-header {
    text-align: center;
    margin-bottom: 40px;
  }

  #cm-{{ section.id }} .cm-heading {
    font-size: 34px;
    font-weight: 700;
    color: #101a32;
    margin: 0 0 14px;
    line-height: 1.2;
  }

  #cm-{{ section.id }} .cm-subtitle {
    font-size: 15px;
    line-height: 1.6;
    color: #555;
    margin: 0;
    max-width: 650px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Grid ── */
  #cm-{{ section.id }} .cm-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  /* ── Card ── */
  #cm-{{ section.id }} .cm-card {
    background: #fff;
    border-radius: 14px;
    padding: 36px 32px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.2s ease;
  }

  #cm-{{ section.id }} .cm-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  #cm-{{ section.id }} .cm-card__icon {
    width: 44px;
    height: 44px;
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #cm-{{ section.id }} .cm-card__icon img {
    width: 36px;
    height: 36px;
    object-fit: contain;
  }

  #cm-{{ section.id }} .cm-card__icon--emoji {
    font-size: 28px;
  }

  #cm-{{ section.id }} .cm-card__title {
    font-size: 20px;
    font-weight: 700;
    color: #101a32;
    margin: 0 0 12px;
    line-height: 1.3;
  }

  #cm-{{ section.id }} .cm-card__desc {
    font-size: 14px;
    line-height: 1.7;
    color: #555;
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    #cm-{{ section.id }} .cm-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    #cm-{{ section.id }} .cm-heading {
      font-size: 28px;
    }

    #cm-{{ section.id }} .cm-card {
      padding: 28px 24px;
    }
  }
</style>

{% schema %}
{
  "name": "Control Modes",
  "tag": "div",
  "class": "control-modes-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "4 Modes Of Control At Your Fingertips"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "You can easily control all functions of NuraCom Stratos even from the convenience of your smartphone."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f9f9f9"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "mode_card",
      "name": "Mode Card",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "icon_emoji",
          "label": "Icon Emoji (fallback if no image)",
          "info": "e.g. a symbol or emoji character"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Remote Control"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Equipped with a remote control that offers convenient and easy operation within a range of 30 metres."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Control Modes",
      "blocks": [
        {
          "type": "mode_card",
          "settings": {
            "title": "Remote Control",
            "description": "Equipped with a remote control that offers convenient and easy operation within a range of 30 metres. No need to get up from your comfortable spot, simply adjust the settings from wherever you are."
          }
        },
        {
          "type": "mode_card",
          "settings": {
            "title": "Wall Switch Control",
            "description": "Our wall switch operation is designed to make laundry drying effortless and intuitive. Simply press the switch twice to turn on the light, four times to activate the descent, and six times to ascend."
          }
        },
        {
          "type": "mode_card",
          "settings": {
            "title": "Mobile App Control",
            "description": "Turn on the light, adjust the blower or heater, and schedule on/off timings to save on electricity. Stay connected and control your laundry experience, no matter where you are."
          }
        },
        {
          "type": "mode_card",
          "settings": {
            "title": "Voice Control",
            "description": "Experience the ultimate hands-free convenience with voice-activated commands. With a simple voice prompt, you can quickly turn on and off the light, activate the blower, switch on the heater, and more."
          }
        }
      ]
    }
  ]
}
{% endschema %}
