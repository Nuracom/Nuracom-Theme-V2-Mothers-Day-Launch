{% comment %}
  Nuracom Shift — Belief bridge (problem-aware → solution-aware).
  Engaging dark cinematic moment: animated glow orbs, pill tag, glowing emphasis,
  staggered reveal, central icon, scroll-prompt.
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    --brand-deep: {{ section.settings.brand_deep }};
    --brand-accent: {{ section.settings.brand_accent }};
    --navy: {{ section.settings.navy }};
    --white: {{ section.settings.white }};
    --emphasis: {{ section.settings.emphasis_color }};
    --max-width: 1120px;
    --section-pad: clamp(56px, 7.5vw, 100px);
  }
  #shopify-section-{{ section.id }} * { box-sizing: border-box; }
  #shopify-section-{{ section.id }} .nshift { padding: var(--section-pad) 0 calc(var(--section-pad) * 0.8); background: var(--navy); color: var(--white); position: relative; overflow: hidden; font-family: 'Inter', -apple-system, sans-serif; }

  /* Ambient orbs */
  #shopify-section-{{ section.id }} .nshift__orb { position: absolute; border-radius: 50%; filter: blur(80px); pointer-events: none; opacity: 0.55; }
  #shopify-section-{{ section.id }} .nshift__orb--1 { width: 520px; height: 520px; top: -120px; left: -140px; background: radial-gradient(circle, {{ section.settings.brand_deep }}80 0%, transparent 70%); animation: nshift-drift-a 14s ease-in-out infinite alternate; }
  #shopify-section-{{ section.id }} .nshift__orb--2 { width: 480px; height: 480px; bottom: -160px; right: -120px; background: radial-gradient(circle, {{ section.settings.emphasis_color }}55 0%, transparent 70%); animation: nshift-drift-b 18s ease-in-out infinite alternate; }
  #shopify-section-{{ section.id }} .nshift__orb--3 { width: 280px; height: 280px; top: 40%; left: 55%; background: radial-gradient(circle, {{ section.settings.brand_accent }}66 0%, transparent 70%); animation: nshift-drift-c 22s ease-in-out infinite alternate; }
  @keyframes nshift-drift-a { 0% { transform: translate(0, 0); } 100% { transform: translate(60px, 40px); } }
  @keyframes nshift-drift-b { 0% { transform: translate(0, 0); } 100% { transform: translate(-50px, -60px); } }
  @keyframes nshift-drift-c { 0% { transform: translate(-20px, 0) scale(1); } 100% { transform: translate(20px, 40px) scale(1.15); } }

  /* Starfield dot grid (subtle) */
  #shopify-section-{{ section.id }} .nshift__grid { position: absolute; inset: 0; background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px); background-size: 32px 32px; opacity: 0.5; mask-image: radial-gradient(ellipse at center, black 30%, transparent 85%); -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 85%); pointer-events: none; }

  #shopify-section-{{ section.id }} .nshift__container { max-width: var(--max-width); margin: 0 auto; padding: 0 24px; position: relative; z-index: 2; }
  #shopify-section-{{ section.id }} .nshift__inner { max-width: 820px; margin: 0 auto; text-align: center; }

  /* Tag pill */
  #shopify-section-{{ section.id }} .nshift__tag { display: inline-flex; align-items: center; gap: 10px; padding: 8px 18px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.14); backdrop-filter: blur(12px); border-radius: 100px; font-size: 0.72rem; letter-spacing: 3px; font-weight: 700; text-transform: uppercase; color: rgba(255,255,255,0.85); margin-bottom: 28px; }
  #shopify-section-{{ section.id }} .nshift__tag-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--emphasis); box-shadow: 0 0 10px var(--emphasis); animation: nshift-pulse 2.2s ease-in-out infinite; }
  @keyframes nshift-pulse { 0%, 100% { opacity: 1; box-shadow: 0 0 12px var(--emphasis); } 50% { opacity: 0.5; box-shadow: 0 0 4px var(--emphasis); } }

  /* Headline */
  #shopify-section-{{ section.id }} .nshift__headline { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(2.4rem, 5.5vw, 4.2rem); font-weight: 700; line-height: 1.08; letter-spacing: -0.5px; margin: 0 0 32px; }
  #shopify-section-{{ section.id }} .nshift__headline p { margin: 0; }
  #shopify-section-{{ section.id }} .nshift__headline em { font-style: italic; color: var(--emphasis); position: relative; display: inline-block; text-shadow: 0 0 30px {{ section.settings.emphasis_color }}55, 0 0 60px {{ section.settings.emphasis_color }}2a; animation: nshift-glow 3.5s ease-in-out infinite; }
  @keyframes nshift-glow { 0%, 100% { text-shadow: 0 0 30px {{ section.settings.emphasis_color }}55, 0 0 60px {{ section.settings.emphasis_color }}2a; } 50% { text-shadow: 0 0 50px {{ section.settings.emphasis_color }}7a, 0 0 100px {{ section.settings.emphasis_color }}40; } }

  /* Staccato paragraphs */
  #shopify-section-{{ section.id }} .nshift__stacatto { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.15rem, 1.7vw, 1.45rem); line-height: 1.6; margin: 0 0 18px; color: rgba(255,255,255,0.88); font-style: italic; }
  #shopify-section-{{ section.id }} .nshift__stacatto strong { color: var(--white); font-weight: 700; font-style: normal; }

  #shopify-section-{{ section.id }} .nshift__text { font-size: clamp(1rem, 1.3vw, 1.1rem); color: rgba(255,255,255,0.72); line-height: 1.8; margin: 0 auto 14px; max-width: 680px; }
  #shopify-section-{{ section.id }} .nshift__text strong { color: var(--white); font-weight: 600; }

  /* Central divider ornament */
  #shopify-section-{{ section.id }} .nshift__ornament { display: flex; align-items: center; justify-content: center; gap: 16px; margin: 38px 0; position: relative; }
  #shopify-section-{{ section.id }} .nshift__ornament-line { width: 60px; height: 1px; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent); }
  #shopify-section-{{ section.id }} .nshift__ornament-orb { width: 10px; height: 10px; border-radius: 50%; background: var(--brand-accent); box-shadow: 0 0 16px {{ section.settings.brand_accent }}aa, 0 0 32px {{ section.settings.brand_accent }}55; animation: nshift-ornament 3s ease-in-out infinite; }
  @keyframes nshift-ornament { 0%, 100% { transform: scale(1); opacity: 0.9; } 50% { transform: scale(1.35); opacity: 1; } }

  /* Answer block */
  #shopify-section-{{ section.id }} .nshift__answer { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.3rem, 2vw, 1.7rem); font-weight: 700; color: var(--white); line-height: 1.35; margin: 0 0 10px; letter-spacing: -0.2px; }
  #shopify-section-{{ section.id }} .nshift__answer-sub { font-size: 0.95rem; color: rgba(255,255,255,0.68); line-height: 1.6; margin: 0; }

  /* Scroll hint */
  #shopify-section-{{ section.id }} .nshift__hint { margin-top: 44px; display: inline-flex; flex-direction: column; align-items: center; gap: 8px; color: rgba(255,255,255,0.6); font-size: 0.72rem; font-weight: 600; letter-spacing: 2.4px; text-transform: uppercase; }
  #shopify-section-{{ section.id }} .nshift__hint-arrow { width: 22px; height: 22px; border: 2px solid rgba(255,255,255,0.4); border-radius: 50%; display: flex; align-items: center; justify-content: center; animation: nshift-bob 2s ease-in-out infinite; }
  @keyframes nshift-bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(5px); } }

  /* Reveal staggering */
  #shopify-section-{{ section.id }} .nshift__reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.9s ease, transform 0.9s ease; }
  #shopify-section-{{ section.id }} .nshift__reveal.is-visible { opacity: 1; transform: translateY(0); }
  #shopify-section-{{ section.id }} .nshift__reveal--d1 { transition-delay: 0.05s; }
  #shopify-section-{{ section.id }} .nshift__reveal--d2 { transition-delay: 0.2s; }
  #shopify-section-{{ section.id }} .nshift__reveal--d3 { transition-delay: 0.35s; }
  #shopify-section-{{ section.id }} .nshift__reveal--d4 { transition-delay: 0.5s; }
  #shopify-section-{{ section.id }} .nshift__reveal--d5 { transition-delay: 0.65s; }
  #shopify-section-{{ section.id }} .nshift__reveal--d6 { transition-delay: 0.8s; }

  @media (max-width: 700px) {
    #shopify-section-{{ section.id }} .nshift__orb { filter: blur(60px); opacity: 0.4; }
    #shopify-section-{{ section.id }} .nshift__orb--1 { width: 340px; height: 340px; }
    #shopify-section-{{ section.id }} .nshift__orb--2 { width: 320px; height: 320px; }
    #shopify-section-{{ section.id }} .nshift__tag { font-size: 0.68rem; padding: 6px 14px; letter-spacing: 2px; }
    #shopify-section-{{ section.id }} .nshift__ornament { margin: 28px 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .nshift__orb,
    #shopify-section-{{ section.id }} .nshift__tag-dot,
    #shopify-section-{{ section.id }} .nshift__headline em,
    #shopify-section-{{ section.id }} .nshift__ornament-orb,
    #shopify-section-{{ section.id }} .nshift__hint-arrow { animation: none; }
  }
</style>

<section class="nshift">
  <div class="nshift__orb nshift__orb--1" aria-hidden="true"></div>
  <div class="nshift__orb nshift__orb--2" aria-hidden="true"></div>
  <div class="nshift__orb nshift__orb--3" aria-hidden="true"></div>
  <div class="nshift__grid" aria-hidden="true"></div>

  <div class="nshift__container">
    <div class="nshift__inner">
      {% if section.settings.tag_text != blank %}
        <div class="nshift__tag nshift__reveal nshift__reveal--d1">
          <span class="nshift__tag-dot"></span>
          {{ section.settings.tag_text }}
        </div>
      {% endif %}

      <h2 class="nshift__headline nshift__reveal nshift__reveal--d2">{{ section.settings.headline }}</h2>

      {% if section.settings.text_1 != blank %}
        <p class="nshift__stacatto nshift__reveal nshift__reveal--d3">{{ section.settings.text_1 }}</p>
      {% endif %}

      {% if section.settings.text_2 != blank %}
        <p class="nshift__text nshift__reveal nshift__reveal--d4">{{ section.settings.text_2 }}</p>
      {% endif %}

      {% if section.settings.show_divider %}
        <div class="nshift__ornament nshift__reveal nshift__reveal--d5" aria-hidden="true">
          <span class="nshift__ornament-line"></span>
          <span class="nshift__ornament-orb"></span>
          <span class="nshift__ornament-line"></span>
        </div>
      {% endif %}

      {% if section.settings.answer_text != blank %}
        <p class="nshift__answer nshift__reveal nshift__reveal--d5">{{ section.settings.answer_text }}</p>
      {% endif %}
      {% if section.settings.answer_sub != blank %}
        <p class="nshift__answer-sub nshift__reveal nshift__reveal--d6">{{ section.settings.answer_sub }}</p>
      {% endif %}

      {% if section.settings.show_scroll_hint %}
        <div class="nshift__hint nshift__reveal nshift__reveal--d6" aria-hidden="true">
          {{ section.settings.scroll_hint_text }}
          <span class="nshift__hint-arrow">
            <svg width="10" height="10" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 3v10M4 9l4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<script>
  (function() {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;
    var els = root.querySelectorAll('.nshift__reveal');
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } });
    }, { threshold: 0.2, rootMargin: '0px 0px -60px 0px' });
    els.forEach(function(el) { io.observe(el); });
  })();
</script>

{% schema %}
{
  "name": "Shift / Transformation",
  "tag": "section",
  "class": "nuracom-shift-section",
  "settings": [
    { "type": "header", "content": "Tag pill (above headline)" },
    { "type": "text", "id": "tag_text", "label": "Tag text", "default": "The Turning Point" },
    { "type": "header", "content": "Headline" },
    { "type": "richtext", "id": "headline", "label": "Headline (wrap key words in <em> for italic glow)", "default": "<p>What if drying clothes indoors was <em>actually solved?</em></p>" },
    { "type": "header", "content": "Body copy" },
    { "type": "textarea", "id": "text_1", "label": "Staccato line (italic, larger)", "default": "Not managed. Not tolerated. Not worked around with cheap racks and crossed fingers." },
    { "type": "textarea", "id": "text_2", "label": "Body paragraph", "default": "What if there was a system that dried your clothes in hours — every time, rain or shine — using less power than a light bulb? A system you could mount once, operate with one touch, and never think about again?" },
    { "type": "checkbox", "id": "show_divider", "label": "Show glowing ornament divider", "default": true },
    { "type": "header", "content": "Answer / reveal" },
    { "type": "text", "id": "answer_text", "label": "Answer (bold serif)", "default": "There is." },
    { "type": "text", "id": "answer_sub", "label": "Follow-up line", "default": "And the technology behind it is simpler than you'd expect." },
    { "type": "header", "content": "Scroll hint (bottom)" },
    { "type": "checkbox", "id": "show_scroll_hint", "label": "Show animated scroll-down prompt", "default": true },
    { "type": "text", "id": "scroll_hint_text", "label": "Hint label", "default": "See how" },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "navy", "label": "Background navy", "default": "#101a32" },
    { "type": "color", "id": "brand_deep", "label": "Top-left ambient glow", "default": "#5E0404" },
    { "type": "color", "id": "brand_accent", "label": "Ornament orb + accent", "default": "#a8321a" },
    { "type": "color", "id": "emphasis_color", "label": "Italic glow emphasis", "default": "#f8a89a" },
    { "type": "color", "id": "white", "label": "Text colour", "default": "#ffffff" }
  ],
  "presets": [ { "name": "Shift / Transformation" } ]
}
{% endschema %}
