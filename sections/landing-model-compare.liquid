{% comment %}
  Nuracom Landing — Compare the 3 Models Early
  3 model cards with price, size, key difference, "best for", and CTA.
  Add a "Most Popular" badge on the model you want to push.
  Install to: sections/landing-model-compare.liquid
{% endcomment %}

<style>
  #lp-models-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 90px 24px;
  }

  #lp-models-{{ section.id }} .lp-models__inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  #lp-models-{{ section.id }} .lp-models__header {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 56px;
  }

  #lp-models-{{ section.id }} .lp-models__eyebrow {
    font-size: 12px;
    letter-spacing: 2.4px;
    text-transform: uppercase;
    font-weight: 700;
    color: {{ section.settings.accent_color }};
    margin: 0 0 14px;
  }

  #lp-models-{{ section.id }} .lp-models__heading {
    font-size: clamp(28px, 3.8vw, 44px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.4px;
    margin: 0 0 16px;
  }

  #lp-models-{{ section.id }} .lp-models__subheading {
    font-size: 17px;
    line-height: 1.6;
    opacity: 0.75;
    margin: 0;
  }

  #lp-models-{{ section.id }} .lp-models__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: stretch;
  }

  #lp-models-{{ section.id }} .lp-models__card {
    position: relative;
    background: {{ section.settings.card_bg }};
    border: 1.5px solid {{ section.settings.card_border }};
    border-radius: 18px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  #lp-models-{{ section.id }} .lp-models__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(16,26,50,0.12);
  }

  #lp-models-{{ section.id }} .lp-models__card--popular {
    border-color: {{ section.settings.popular_color }};
    box-shadow: 0 12px 36px rgba(16,26,50,0.18);
    transform: translateY(-4px);
  }

  #lp-models-{{ section.id }} .lp-models__card--premium {
    border-color: {{ section.settings.accent_color }};
    box-shadow: 0 12px 36px rgba(134,102,83,0.18);
    transform: translateY(-4px);
  }

  #lp-models-{{ section.id }} .lp-models__badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    color: #fff;
    font-size: 11.5px;
    font-weight: 800;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 999px;
    white-space: nowrap;
  }

  #lp-models-{{ section.id }} .lp-models__card--popular .lp-models__badge {
    background: {{ section.settings.popular_color }};
  }

  #lp-models-{{ section.id }} .lp-models__card--premium .lp-models__badge {
    background: {{ section.settings.accent_color }};
  }

  #lp-models-{{ section.id }} .lp-models__image {
    aspect-ratio: 4/3;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 22px;
    background: {{ section.settings.image_bg }};
  }

  #lp-models-{{ section.id }} .lp-models__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #lp-models-{{ section.id }} .lp-models__name {
    font-size: 26px;
    font-weight: 800;
    margin: 0 0 6px;
    letter-spacing: -0.3px;
  }

  #lp-models-{{ section.id }} .lp-models__tagline {
    font-size: 14.5px;
    line-height: 1.5;
    opacity: 0.75;
    margin: 0 0 18px;
    min-height: 44px;
  }

  #lp-models-{{ section.id }} .lp-models__price {
    font-size: 32px;
    font-weight: 800;
    margin: 0 0 4px;
    color: {{ section.settings.text_color }};
  }

  #lp-models-{{ section.id }} .lp-models__price-note {
    font-size: 12px;
    opacity: 0.6;
    margin: 0 0 22px;
  }

  #lp-models-{{ section.id }} .lp-models__specs {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 18px 0;
    border-top: 1px solid {{ section.settings.card_border }};
    border-bottom: 1px solid {{ section.settings.card_border }};
    margin-bottom: 22px;
  }

  #lp-models-{{ section.id }} .lp-models__spec {
    display: flex;
    justify-content: space-between;
    font-size: 13.5px;
  }

  #lp-models-{{ section.id }} .lp-models__spec-label {
    opacity: 0.65;
  }

  #lp-models-{{ section.id }} .lp-models__spec-val {
    font-weight: 600;
  }

  #lp-models-{{ section.id }} .lp-models__best {
    font-size: 13.5px;
    line-height: 1.5;
    margin: 0 0 22px;
    padding: 12px 14px;
    background: {{ section.settings.highlight_bg }};
    border-left: 3px solid {{ section.settings.accent_color }};
    border-radius: 0 6px 6px 0;
  }

  #lp-models-{{ section.id }} .lp-models__best strong {
    display: block;
    font-size: 11.5px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 2px;
  }

  #lp-models-{{ section.id }} .lp-models__cta {
    margin-top: auto;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    padding: 14px 20px;
    background: {{ section.settings.cta_bg }};
    color: {{ section.settings.cta_text }};
    border-radius: 8px;
    font-size: 14.5px;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.12s ease;
    letter-spacing: 0.3px;
  }

  #lp-models-{{ section.id }} .lp-models__cta:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  #lp-models-{{ section.id }} .lp-models__card--popular .lp-models__cta {
    background: {{ section.settings.popular_color }};
  }

  #lp-models-{{ section.id }} .lp-models__card--premium .lp-models__cta {
    background: {{ section.settings.accent_color }};
  }

  #lp-models-{{ section.id }} .lp-models__scroll-hint {
    display: none;
    text-align: center;
    font-size: 12.5px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    font-weight: 600;
    opacity: 0.55;
    margin-top: 18px;
  }

  @media (max-width: 960px) {
    #lp-models-{{ section.id }} .lp-models__grid {
      display: flex;
      grid-template-columns: none;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 14px;
      padding: 10px 20px 18px;
      margin: -10px -24px 0;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    #lp-models-{{ section.id }} .lp-models__grid::-webkit-scrollbar {
      display: none;
    }
    #lp-models-{{ section.id }} .lp-models__card {
      flex: 0 0 86%;
      max-width: 360px;
      min-width: 260px;
      scroll-snap-align: center;
      padding: 24px 22px;
    }
    #lp-models-{{ section.id }} .lp-models__card--popular {
      transform: none;
    }
    #lp-models-{{ section.id }} .lp-models__image {
      aspect-ratio: 16/10;
      margin-bottom: 16px;
    }
    #lp-models-{{ section.id }} .lp-models__name {
      font-size: 22px;
    }
    #lp-models-{{ section.id }} .lp-models__tagline {
      font-size: 13.5px;
      min-height: 0;
      margin-bottom: 14px;
    }
    #lp-models-{{ section.id }} .lp-models__price {
      font-size: 26px;
    }
    #lp-models-{{ section.id }} .lp-models__price-note {
      margin-bottom: 16px;
    }
    #lp-models-{{ section.id }} .lp-models__specs {
      padding: 14px 0;
      gap: 8px;
      margin-bottom: 16px;
    }
    #lp-models-{{ section.id }} .lp-models__spec {
      font-size: 12.5px;
    }
    #lp-models-{{ section.id }} .lp-models__best {
      font-size: 12.5px;
      padding: 10px 12px;
      margin-bottom: 16px;
    }
    #lp-models-{{ section.id }} .lp-models__cta {
      padding: 12px 16px;
      font-size: 14px;
    }
    #lp-models-{{ section.id }} .lp-models__scroll-hint {
      display: block;
    }
  }

  @media (max-width: 560px) {
    #lp-models-{{ section.id }} {
      padding: 60px 18px;
    }
    #lp-models-{{ section.id }} .lp-models__grid {
      margin: -10px -18px 0;
      padding: 10px 18px 18px;
    }
  }
</style>

<section id="lp-models-{{ section.id }}">
  <div class="lp-models__inner">
    <div class="lp-models__header">
      {% if section.settings.eyebrow != blank %}
        <p class="lp-models__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="lp-models__heading">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="lp-models__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="lp-models__grid">
      {% for block in section.blocks %}
        {%- assign highlight = block.settings.highlight_style | default: 'none' -%}
        <article class="lp-models__card{% if highlight == 'popular' %} lp-models__card--popular{% elsif highlight == 'premium' %} lp-models__card--premium{% endif %}" {{ block.shopify_attributes }}>
          {% if highlight != 'none' and block.settings.popular_label != blank %}
            <span class="lp-models__badge">{{ block.settings.popular_label }}</span>
          {% endif %}

          <div class="lp-models__image">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.name | escape }}" loading="lazy">
            {% else %}
              {{ 'product-1' | placeholder_svg_tag }}
            {% endif %}
          </div>

          <h3 class="lp-models__name">{{ block.settings.name }}</h3>
          <p class="lp-models__tagline">{{ block.settings.tagline }}</p>

          <p class="lp-models__price">{{ block.settings.price }}</p>
          {% if block.settings.price_note != blank %}
            <p class="lp-models__price-note">{{ block.settings.price_note }}</p>
          {% endif %}

          <div class="lp-models__specs">
            {% if block.settings.spec_size != blank %}
              <div class="lp-models__spec">
                <span class="lp-models__spec-label">Size</span>
                <span class="lp-models__spec-val">{{ block.settings.spec_size }}</span>
              </div>
            {% endif %}
            {% if block.settings.spec_capacity != blank %}
              <div class="lp-models__spec">
                <span class="lp-models__spec-label">Capacity</span>
                <span class="lp-models__spec-val">{{ block.settings.spec_capacity }}</span>
              </div>
            {% endif %}
            {% if block.settings.spec_key_diff != blank %}
              <div class="lp-models__spec">
                <span class="lp-models__spec-label">Key difference</span>
                <span class="lp-models__spec-val">{{ block.settings.spec_key_diff }}</span>
              </div>
            {% endif %}
            {% if block.settings.spec_running_cost != blank %}
              <div class="lp-models__spec">
                <span class="lp-models__spec-label">Running cost</span>
                <span class="lp-models__spec-val">{{ block.settings.spec_running_cost }}</span>
              </div>
            {% endif %}
          </div>

          {% if block.settings.best_for != blank %}
            <div class="lp-models__best">
              <strong>Best for</strong>
              {{ block.settings.best_for }}
            </div>
          {% endif %}

          <a href="{{ block.settings.cta_url }}" class="lp-models__cta">
            {{ block.settings.cta_text }}
          </a>
        </article>
      {% endfor %}
    </div>

    <p class="lp-models__scroll-hint" aria-hidden="true">← Swipe to compare →</p>
  </div>
</section>

{% schema %}
{
  "name": "Landing — Model Compare",
  "tag": "section",
  "class": "landing-models-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Choose your model" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose the Nuracom that fits your space and drying needs" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Three models, each purpose-built. We'll tell you which one to pick — so you don't have to guess." },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#f7f5f1" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#101a32" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#866653" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#ffffff" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#e8e4dc" },
    { "type": "color", "id": "image_bg", "label": "Image placeholder bg", "default": "#f3efe8" },
    { "type": "color", "id": "highlight_bg", "label": "Best-for strip bg", "default": "#faf6f0" },
    { "type": "color", "id": "cta_bg", "label": "CTA button bg", "default": "#101a32" },
    { "type": "color", "id": "cta_text", "label": "CTA button text", "default": "#ffffff" },
    { "type": "color", "id": "popular_color", "label": "\"Most Popular\" card colour (blue)", "default": "#101a32" }
  ],
  "blocks": [
    {
      "type": "model",
      "name": "Model card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Model image" },
        { "type": "text", "id": "name", "label": "Model name", "default": "Aero" },
        { "type": "text", "id": "tagline", "label": "Tagline", "default": "Best for balanced performance and everyday family use" },
        { "type": "text", "id": "price", "label": "Price", "default": "$1,299" },
        { "type": "text", "id": "price_note", "label": "Price note", "default": "or 4 interest-free payments" },
        { "type": "text", "id": "spec_size", "label": "Spec — Size", "default": "1.2m" },
        { "type": "text", "id": "spec_capacity", "label": "Spec — Capacity", "default": "Up to 15kg" },
        { "type": "text", "id": "spec_key_diff", "label": "Spec — Key difference", "default": "Heated drying + lighting" },
        { "type": "text", "id": "spec_running_cost", "label": "Spec — Running cost", "default": "~$0.57 per 2hr cycle" },
        { "type": "textarea", "id": "best_for", "label": "Best for (who this suits)", "default": "Families doing 4+ loads a week who want faster drying without committing to a dryer." },
        {
          "type": "select",
          "id": "highlight_style",
          "label": "Highlight style",
          "default": "none",
          "options": [
            { "value": "none", "label": "None (standard card)" },
            { "value": "popular", "label": "Most Popular (blue highlight)" },
            { "value": "premium", "label": "Top of Range (accent highlight)" }
          ]
        },
        { "type": "text", "id": "popular_label", "label": "Badge label", "default": "Most Popular" },
        { "type": "text", "id": "cta_text", "label": "CTA text", "default": "View Aero" },
        { "type": "url", "id": "cta_url", "label": "CTA URL" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Landing — Model Compare",
      "blocks": [
        {
          "type": "model",
          "settings": {
            "name": "Breeze",
            "tagline": "Best for smaller spaces and essential indoor drying",
            "price": "$899",
            "spec_size": "0.9m",
            "spec_capacity": "Up to 10kg",
            "spec_key_diff": "Smart controls + lighting",
            "spec_running_cost": "~$0.57 per cycle",
            "best_for": "Apartments, units, and homes with limited laundry space.",
            "cta_text": "View Breeze"
          }
        },
        {
          "type": "model",
          "settings": {
            "name": "Aero",
            "tagline": "Best for balanced performance and everyday family use",
            "price": "$1,299",
            "spec_size": "1.2m",
            "spec_capacity": "Up to 15kg",
            "spec_key_diff": "Heated drying + lighting",
            "spec_running_cost": "~$0.57 per cycle",
            "best_for": "Families doing 4+ loads a week who want faster drying without committing to a dryer.",
            "highlight_style": "popular",
            "popular_label": "Most Popular",
            "cta_text": "View Aero"
          }
        },
        {
          "type": "model",
          "settings": {
            "name": "Stratos",
            "tagline": "Best for premium homes wanting maximum features and drying power",
            "price": "$1,799",
            "spec_size": "1.5m telescopic",
            "spec_capacity": "Up to 25kg",
            "spec_key_diff": "Telescopic + heated + premium",
            "spec_running_cost": "~$0.64 per cycle",
            "best_for": "Large families, renovations, and homes where laundry volume and premium finish matter.",
            "highlight_style": "premium",
            "popular_label": "Top of Range",
            "cta_text": "View Stratos"
          }
        }
      ]
    }
  ]
}
{% endschema %}
