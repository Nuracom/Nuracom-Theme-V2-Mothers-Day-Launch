{% comment %}
  Nuracom Final CTA — All 6 beliefs held. The close.
  Outcome-focused headline + 2 CTAs + assurance chips.
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    --brand-deep: {{ section.settings.brand_deep }};
    --brand-dark: {{ section.settings.brand_dark }};
    --navy: {{ section.settings.navy }};
    --text-secondary: {{ section.settings.text_secondary }};
    --text-muted: {{ section.settings.text_muted }};
    --white: {{ section.settings.white }};
    --check: {{ section.settings.check_color }};
    --max-width: 1120px;
    --section-pad: clamp(48px, 6.5vw, 90px);
  }
  #shopify-section-{{ section.id }} * { box-sizing: border-box; }
  #shopify-section-{{ section.id }} .nfcta { padding: var(--section-pad) 0; background: {{ section.settings.bg_color }}; font-family: 'Inter', -apple-system, sans-serif; }
  #shopify-section-{{ section.id }} .nfcta__container { max-width: var(--max-width); margin: 0 auto; padding: 0 24px; }
  #shopify-section-{{ section.id }} .nfcta__inner { max-width: 700px; margin: 0 auto; text-align: center; }
  #shopify-section-{{ section.id }} .nfcta__headline { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: var(--navy); margin: 0 0 16px; line-height: 1.2; }
  #shopify-section-{{ section.id }} .nfcta__headline em { color: var(--brand-deep); font-style: italic; }
  #shopify-section-{{ section.id }} .nfcta__headline p { margin: 0; }
  #shopify-section-{{ section.id }} .nfcta__text { font-size: 1.1rem; color: var(--text-secondary); line-height: 1.7; margin: 0 auto 32px; max-width: 560px; }
  #shopify-section-{{ section.id }} .nfcta__buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-bottom: 24px; }
  #shopify-section-{{ section.id }} .nfcta__btn { display: inline-flex; align-items: center; gap: 8px; padding: 18px 48px; font-size: 1.1rem; font-weight: 600; border-radius: 10px; cursor: pointer; border: 2px solid transparent; text-decoration: none; transition: all 0.3s ease; white-space: nowrap; font-family: inherit; }
  #shopify-section-{{ section.id }} .nfcta__btn--primary { background: var(--brand-deep); color: var(--white); }
  #shopify-section-{{ section.id }} .nfcta__btn--primary:hover { background: var(--brand-dark); transform: translateY(-2px); box-shadow: 0 8px 24px {{ section.settings.brand_deep }}4d; }
  #shopify-section-{{ section.id }} .nfcta__btn--outline { background: transparent; color: var(--brand-deep); border-color: var(--brand-deep); }
  #shopify-section-{{ section.id }} .nfcta__btn--outline:hover { background: var(--brand-deep); color: var(--white); }
  #shopify-section-{{ section.id }} .nfcta__btn-arrow { transition: transform 0.3s ease; }
  #shopify-section-{{ section.id }} .nfcta__btn:hover .nfcta__btn-arrow { transform: translateX(4px); }
  #shopify-section-{{ section.id }} .nfcta__assurance { display: flex; justify-content: center; gap: 24px; flex-wrap: wrap; }
  #shopify-section-{{ section.id }} .nfcta__assurance-item { display: inline-flex; align-items: center; gap: 6px; font-size: 0.85rem; color: var(--text-muted); }
  #shopify-section-{{ section.id }} .nfcta__assurance-icon { color: var(--check); font-weight: 700; }
  #shopify-section-{{ section.id }} .nfcta__reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
  #shopify-section-{{ section.id }} .nfcta__reveal.is-visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 600px) {
    #shopify-section-{{ section.id }} .nfcta__buttons { flex-direction: column; align-items: center; }
    #shopify-section-{{ section.id }} .nfcta__btn { width: 100%; justify-content: center; max-width: 360px; }
    #shopify-section-{{ section.id }} .nfcta__assurance { gap: 12px; }
  }
</style>

<section class="nfcta">
  <div class="nfcta__container">
    <div class="nfcta__inner nfcta__reveal">
      <h2 class="nfcta__headline">{{ section.settings.headline }}</h2>
      {% if section.settings.subtext != blank %}
        <p class="nfcta__text">{{ section.settings.subtext }}</p>
      {% endif %}

      <div class="nfcta__buttons">
        {% if section.settings.primary_btn_text != blank %}
          <a href="{{ section.settings.primary_btn_url | default: '#' }}" class="nfcta__btn nfcta__btn--primary">
            {{ section.settings.primary_btn_text }}
            <span class="nfcta__btn-arrow">&rarr;</span>
          </a>
        {% endif %}
        {% if section.settings.secondary_btn_text != blank %}
          <a href="{{ section.settings.secondary_btn_url | default: '#' }}" class="nfcta__btn nfcta__btn--outline">
            {{ section.settings.secondary_btn_text }}
          </a>
        {% endif %}
      </div>

      {%- comment -%} Render checkmarks — prefer section settings, fall back to blocks {%- endcomment -%}
      {%- assign has_settings_checks = false -%}
      {%- for i in (1..8) -%}
        {%- assign key = 'check_' | append: i -%}
        {%- if section.settings[key] != blank -%}{%- assign has_settings_checks = true -%}{%- endif -%}
      {%- endfor -%}

      {% if has_settings_checks %}
        <div class="nfcta__assurance">
          {% for i in (1..8) %}
            {% assign key = 'check_' | append: i %}
            {% assign v = section.settings[key] %}
            {% if v != blank %}
              <span class="nfcta__assurance-item">
                <span class="nfcta__assurance-icon">&check;</span>
                {{ v }}
              </span>
            {% endif %}
          {% endfor %}
        </div>
      {% elsif section.blocks.size > 0 %}
        <div class="nfcta__assurance">
          {% for block in section.blocks %}
            <span class="nfcta__assurance-item" {{ block.shopify_attributes }}>
              <span class="nfcta__assurance-icon">&check;</span>
              {{ block.settings.text }}
            </span>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<script>
  (function() {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;
    var els = root.querySelectorAll('.nfcta__reveal');
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
    els.forEach(function(el) { io.observe(el); });
  })();
</script>

{% schema %}
{
  "name": "Final CTA",
  "tag": "section",
  "class": "nuracom-final-cta-section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "richtext", "id": "headline", "label": "Headline (wrap words in <em> for italic brand-colour emphasis)", "default": "<p>Ready to Never Worry About <em>Drying Laundry</em> Again?</p>" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Join hundreds of Australian families who've permanently solved indoor drying. One purchase. One install. A lifetime of perfect dries." },
    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "primary_btn_text", "label": "Primary button text", "default": "Shop the Range" },
    { "type": "url", "id": "primary_btn_url", "label": "Primary button URL" },
    { "type": "text", "id": "secondary_btn_text", "label": "Secondary button text", "default": "See How It Works" },
    { "type": "url", "id": "secondary_btn_url", "label": "Secondary button URL" },
    { "type": "header", "content": "Green-tick checkmark chips", "info": "Each non-empty field below renders as a green tick + text chip under the buttons. Leave blank to hide." },
    { "type": "text", "id": "check_1", "label": "Checkmark 1", "default": "Free Australian shipping" },
    { "type": "text", "id": "check_2", "label": "Checkmark 2", "default": "Up to 5-year warranty" },
    { "type": "text", "id": "check_3", "label": "Checkmark 3", "default": "Under $1 per use" },
    { "type": "text", "id": "check_4", "label": "Checkmark 4", "default": "DIY install in 30 mins" },
    { "type": "text", "id": "check_5", "label": "Checkmark 5 (optional)" },
    { "type": "text", "id": "check_6", "label": "Checkmark 6 (optional)" },
    { "type": "text", "id": "check_7", "label": "Checkmark 7 (optional)" },
    { "type": "text", "id": "check_8", "label": "Checkmark 8 (optional)" },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "brand_deep", "label": "Brand deep", "default": "#5E0404" },
    { "type": "color", "id": "brand_dark", "label": "CTA hover", "default": "#801f0a" },
    { "type": "color", "id": "navy", "label": "Navy (heading)", "default": "#101a32" },
    { "type": "color", "id": "text_secondary", "label": "Body text", "default": "#555555" },
    { "type": "color", "id": "text_muted", "label": "Assurance text", "default": "#888888" },
    { "type": "color", "id": "white", "label": "Button text", "default": "#ffffff" },
    { "type": "color", "id": "check_color", "label": "Tick colour", "default": "#16a34a" }
  ],
  "blocks": [
    {
      "type": "assurance_item",
      "name": "Checkmark chip",
      "settings": [
        { "type": "text", "id": "text", "label": "Checkmark text (e.g. \"Free shipping\")", "default": "Checkmark text", "info": "Each added block becomes a green-tick chip at the bottom of the CTA." }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Final CTA",
      "blocks": [
        { "type": "assurance_item", "settings": { "text": "Free Australian shipping" } },
        { "type": "assurance_item", "settings": { "text": "Up to 5-year warranty" } },
        { "type": "assurance_item", "settings": { "text": "Under $1 per use" } },
        { "type": "assurance_item", "settings": { "text": "DIY install in 30 mins" } }
      ]
    }
  ]
}
{% endschema %}
